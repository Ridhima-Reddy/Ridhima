#Prepare Data
import pandas as pd
import numpy as np

# Load cleaned dataset
df = pd.read_csv("final_multimodal_features_clean.csv")

# Selected features from LASSO + logistic regression
selected_features = ['FractalDim', 'PTR', 'FRC', 'AI', 'FDR', 'SIA', 'GAI']

# Risk points derived from logistic regression coefficients
risk_points = pd.Series([1, -1, 6, 1, 4, 2, 4], index=selected_features)

# Extract selected features & fill NaNs
df_selected = df[selected_features].fillna(0)

# Convert to NumPy arrays
X_selected = df_selected.to_numpy()
risk_points_array = risk_points.to_numpy()

#Compute Total Risk Score
# Compute raw total risk score (sum of feature*points)
df['RiskScore'] = np.dot(X_selected, risk_points_array)

# Convert to predicted probability using logistic function
df['PredictedProb'] = 1 / (1 + np.exp(-df['RiskScore']))

#Scale Risk Score for Clinician Interpretability
# Scale risk scores to a 0–20 point system
max_points = 20
df['RiskScore_scaled'] = df['RiskScore'] / df['RiskScore'].max() * max_points

# Recompute predicted probability using scaled risk score
df['PredictedProb_scaled'] = 1 / (1 + np.exp(-df['RiskScore_scaled']))

#Generate Clinician-Friendly Lookup Table
# Lookup table: unique risk scores → predicted probability
lookup_table = df[['RiskScore_scaled', 'PredictedProb_scaled']].drop_duplicates()
lookup_table = lookup_table.sort_values('RiskScore_scaled').reset_index(drop=True)
print("Sample Lookup Table:")
print(lookup_table.head(10))

