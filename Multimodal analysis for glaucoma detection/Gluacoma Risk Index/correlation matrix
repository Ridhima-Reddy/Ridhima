#Load Dataset and Define Candidate Features
import pandas as pd
import numpy as np

# Load cleaned dataset
df = pd.read_csv("final_multimodal_features_clean.csv")

# Define candidate features
vascular_features = ['VD', 'Tortuosity', 'FractalDim', 'FluxDeficit', 'PTR', 'FRC', 'AI', 'FDR']
structural_features = ['SIA', 'GAI', 'RGCI']
candidate_features = vascular_features + structural_features

# Target variable
# Assuming 'Label' column contains 'Normal' and 'Glaucoma'
df['LabelBinary'] = df['Label'].map({'Normal': 0, 'Glaucoma': 1})

print("Candidate features:", candidate_features)
print("Target variable distribution:")
print(df['LabelBinary'].value_counts())

#Feature Selection
import seaborn as sns
import matplotlib.pyplot as plt

# Compute correlation matrix for candidate features
corr_matrix = df[candidate_features].corr()

plt.figure(figsize=(10,8))
sns.heatmap(corr_matrix, annot=True, cmap="coolwarm")
plt.title("Correlation Matrix of Candidate Features")
plt.show()

# Optional: remove features with correlation > 0.85
upper = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))
to_drop = [col for col in upper.columns if any(upper[col].abs() > 0.85)]
print("Highly correlated features to consider dropping:", to_drop)
