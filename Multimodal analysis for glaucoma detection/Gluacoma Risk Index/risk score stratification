import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import confusion_matrix, roc_auc_score, roc_curve

sns.set(style="whitegrid")

# ------------------------------
# 1️. Risk Stratification
# ------------------------------

# Example: Low, Medium, High based on scaled RiskScore
def categorize_risk(score):
    if score < 5:
        return "Low"
    elif score < 8:
        return "Medium"
    else:
        return "High"

df['RiskCategory'] = df['RiskScore_scaled'].apply(categorize_risk)

# Contingency table
risk_table = pd.crosstab(df['RiskCategory'], df['Label'], margins=True)
print("Risk category vs Label counts:")
print(risk_table)

risk_table_pct = pd.crosstab(df['RiskCategory'], df['Label'], normalize='index') * 100
print("\nPercentage distribution:")
print(risk_table_pct.round(2))

# ------------------------------
# 2️. Interpretability
# ------------------------------

# Feature contributions using risk points
selected_features = ['FractalDim', 'PTR', 'FRC', 'AI', 'FDR', 'SIA', 'GAI']
risk_points = pd.Series([1, -1, 6, 1, 4, 2, 4], index=selected_features)

plt.figure(figsize=(8,5))
risk_points.plot(kind='bar', color='skyblue', title='Feature Contribution to Risk Score')
