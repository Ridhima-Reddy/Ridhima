# 4️. Define interpretable risk categories
# Example thresholds (you can refine based on histogram overlap)
def risk_category(prob):
    if prob >= 0.8:
        return "High Risk"
    elif prob >= 0.5:
        return "Medium Risk"
    else:
        return "Low Risk"

df['RiskCategory'] = df['PredictedProb'].apply(risk_category)

# 5️. Inspect counts per category
print(df['RiskCategory'].value_counts())

# 6️. Optional: Boxplot for RiskScore by RiskCategory
plt.figure(figsize=(8,5))
sns.boxplot(x='RiskCategory', y='RiskScore', data=df, order=["Low Risk", "Medium Risk", "High Risk"])
plt.title("Risk Score by Risk Category")
plt.show()
