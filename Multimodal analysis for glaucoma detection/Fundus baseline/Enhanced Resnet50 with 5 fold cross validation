#Enhanced resnet50 with five fold cross validation
import os
import random
import shutil
import tempfile
from pathlib import Path
from tqdm import tqdm

import torch

# Force CUDA device 4 if available
if torch.cuda.is_available():
    device = torch.device("cuda")
else:
    device = torch.device("cpu")

print("Using device:", device)


import torch.nn as nn
from torch.utils.data import random_split, DataLoader, Subset
import torchvision.transforms as T
import torchvision.models as models
from torchvision.datasets import ImageFolder
from sklearn.metrics import roc_auc_score, accuracy_score, confusion_matrix
from sklearn.model_selection import KFold
import numpy as np


# -------------------------
def set_seed(seed=42):
    random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)


def compute_metrics(y_true, y_probs, threshold=0.5):
    y_true = torch.tensor(y_true).numpy()
    y_probs = torch.tensor(y_probs).numpy()
    auc = roc_auc_score(y_true, y_probs)
    y_pred = (y_probs >= threshold).astype(int)
    acc = accuracy_score(y_true, y_pred)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    sens = tp / (tp + fn)
    spec = tn / (tn + fp)
    return auc, acc, sens, spec


def create_resnet50_model():
    """Create and return a new ResNet-50 model"""
    model = models.resnet50(pretrained=True)
    
    # ENHANCED: More sophisticated classifier head for ResNet-50
    model.fc = nn.Sequential(
        nn.Dropout(0.3),  # ENHANCED: Increased dropout for larger model
        nn.Linear(model.fc.in_features, 512),
        nn.ReLU(inplace=True),
        nn.BatchNorm1d(512),  # NEW: Batch normalization
        nn.Dropout(0.2),  # NEW: Additional dropout
        nn.Linear(512, 1)
    )
    return model.to(device)


def train_fold(model, train_loader, val_loader, fold, epochs=50, lr=1e-4):
    """Train and validate for a single fold"""
    criterion = nn.BCEWithLogitsLoss()
    
    # ENHANCED: Two-stage optimizer strategy for ResNet-50
    optimizer = torch.optim.AdamW([
        {'params': model.conv1.parameters(), 'lr': lr/10},
        {'params': model.bn1.parameters(), 'lr': lr/10},
        {'params': model.layer1.parameters(), 'lr': lr/10},
        {'params': model.layer2.parameters(), 'lr': lr/5},
        {'params': model.layer3.parameters(), 'lr': lr/2},
        {'params': model.layer4.parameters(), 'lr': lr},
        {'params': model.fc.parameters(), 'lr': lr}
    ], weight_decay=1e-4)
    
    # ENHANCED: Cosine annealing with warm restarts
    scheduler = torch.optim.lr_scheduler.CosineAnnealingWarmRestarts(optimizer, T_0=10, T_mult=2)
    
    best_auc = 0.0
    best_metrics = {}
    patience_counter = 0
    patience = 12  # ENHANCED: Increased patience for larger model
    fold_history = []

    print(f"\n🚀 Starting Fold {fold} training:")
    
    for epoch in range(1, epochs + 1):
        model.train()
        total_loss = 0
        
        # ENHANCED: Gradient scaling for mixed precision
        scaler = torch.cuda.amp.GradScaler() if device.type == "cuda" else None
        
        for imgs, labels in tqdm(train_loader, desc=f"Fold{fold} Epoch {epoch}/{epochs}"):
            imgs, labels = imgs.to(device), labels.float().to(device)
            optimizer.zero_grad()
            
            # ENHANCED: Mixed precision training for faster performance
            if device.type == "cuda":
                with torch.cuda.amp.autocast():
                    out = model(imgs).squeeze(1)
                    loss = criterion(out, labels)
                scaler.scale(loss).backward()
                # ENHANCED: Gradient clipping for stability
                scaler.unscale_(optimizer)
                torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
                scaler.step(optimizer)
                scaler.update()
            else:
                out = model(imgs).squeeze(1)
                loss = criterion(out, labels)
                loss.backward()
                torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
                optimizer.step()
                
            total_loss += loss.item() * imgs.size(0)
            
        avg_loss = total_loss / len(train_loader.dataset)
        current_lr = optimizer.param_groups[0]['lr']

        # Validation
        model.eval()
        all_probs, all_labels = [], []
        with torch.no_grad():
            for imgs, labels in val_loader:
                imgs = imgs.to(device)
                out = torch.sigmoid(model(imgs).squeeze(1)).cpu()
                all_probs.extend(out)
                all_labels.extend(labels)
                
        auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
        
        # Update learning rate scheduler
        scheduler.step()
        
        print(f"Fold{fold} Epoch {epoch} | Loss {avg_loss:.4f} | Val AUC {auc:.4f} | Acc {acc:.3f} | Sens {sens:.3f} | Spec {spec:.3f} | LR {current_lr:.2e}")

        fold_history.append({
            'fold': fold, 'epoch': epoch,
            'loss': avg_loss, 'auc': auc, 'acc': acc, 'sens': sens, 'spec': spec
        })

        # ENHANCED: Early stopping and best model tracking
        if auc > best_auc:
            best_auc = auc
            best_metrics = {'auc': auc, 'acc': acc, 'sens': sens, 'spec': spec}
            patience_counter = 0
            # Save only state_dict for safer loading in PyTorch 2.6
            torch.save(
                model.state_dict(), 
                f"Ai in Medicine - Neeraja and Ridhima/best_resnet50_fold{fold}_safe.pth"
            )
            print(f"✅ Saved best model for Fold {fold} (safe format)")
        else:
            patience_counter += 1
            if patience_counter >= patience:
                print(f"🛑 Early stopping triggered at epoch {epoch} for Fold {fold}")
                break

    return best_metrics, fold_history


def safe_load_model_state_dict(model_path, model):
    """Safely load model state dict with PyTorch 2.6 compatibility"""
    try:
        # First try with weights_only=True (safer)
        state_dict = torch.load(model_path, weights_only=True)
        model.load_state_dict(state_dict)
        return True
    except:
        try:
            # If that fails, try with weights_only=False (less secure but works)
            print(f"⚠️  Using weights_only=False for loading fold model. Only use if you trust the source.")
            state_dict = torch.load(model_path, weights_only=False)
            model.load_state_dict(state_dict)
            return True
        except Exception as e:
            print(f"❌ Error loading model for fold: {e}")
            return False


# -------------------------
def main(data_dir="Ai in Medicine - Neeraja and Ridhima/Dataset",
         img_size=224, batch_size=32, epochs=50, lr=1e-4,
         n_splits=5):
    
    device = "cuda" if torch.cuda.is_available() else "cpu"
    print("Device:", device)
    set_seed(42)

    # ---------------- Inspect folder structure ----------------
    print(f"\n📁 Looking inside data directory: {data_dir}")
    if not os.path.exists(data_dir):
        raise FileNotFoundError(f"❌ Data directory not found: {data_dir}")

    print("Subfolders found:")
    for item in os.listdir(data_dir):
        path = os.path.join(data_dir, item)
        if os.path.isdir(path):
            print(f" - {item}/  ({len(os.listdir(path))} files)")
        else:
            print(f" - {item} (file)")

    print("\n🔍 Checking for image samples in each folder:")
    for cls in os.listdir(data_dir):
        cls_path = os.path.join(data_dir, cls)
        if not os.path.isdir(cls_path) or cls.startswith('.'):
            continue
        imgs = [f for f in os.listdir(cls_path) if f.lower().endswith(('.png', '.jpg', '.jpeg', '.tif', '.tiff', '.bmp'))]
        print(f"Class: {cls} | Found {len(imgs)} images")
        if imgs:
            print("  e.g. →", imgs[:3])

    # ---------------- Clean dataset directory ----------------
    valid_class_dirs = [d for d in os.listdir(data_dir)
                        if os.path.isdir(os.path.join(data_dir, d)) and not d.startswith('.')]
    print(f"\n✅ Valid class folders used for training: {valid_class_dirs}\n")

    if len(valid_class_dirs) < 2:
        raise RuntimeError(f"❌ Expected ≥2 class folders but found: {valid_class_dirs}")

    clean_root = tempfile.mkdtemp(prefix="fundus_clean_")
    for cls in valid_class_dirs:
        src = os.path.join(data_dir, cls)
        dst = os.path.join(clean_root, cls)
        shutil.copytree(src, dst)
    print(f"📂 Using cleaned dataset at: {clean_root}")

    # ---------------- ENHANCED Data Transforms ----------------
    train_t = T.Compose([
        T.Resize((img_size, img_size)),
        T.RandomHorizontalFlip(p=0.5),
        T.RandomVerticalFlip(p=0.3),  # ENHANCED: Added vertical flip
        T.RandomRotation(degrees=20),  # ENHANCED: Increased rotation range
        T.RandomAffine(degrees=0, translate=(0.15, 0.15), scale=(0.85, 1.15)),  # ENHANCED: More aggressive augmentation
        T.ColorJitter(brightness=0.3, contrast=0.3, saturation=0.2, hue=0.05),  # ENHANCED: More color variation
        T.GaussianBlur(kernel_size=3, sigma=(0.1, 2.0)),  # NEW: Gaussian blur augmentation
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    val_t = T.Compose([
        T.Resize((img_size, img_size)),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])

    # ---------------- Load dataset safely ----------------
    full_dataset = ImageFolder(root=clean_root, transform=train_t)
    print(f"✅ ImageFolder loaded successfully with {len(full_dataset)} total images")
    print(f"Classes detected: {full_dataset.classes}")

    # ---------------- 5-Fold Cross Validation ----------------
    print(f"\n🎯 Starting {n_splits}-Fold Cross Validation with ResNet-50...")
    
    kfold = KFold(n_splits=n_splits, shuffle=True, random_state=42)
    fold_results = []
    all_histories = []
    
    for fold, (train_idx, val_idx) in enumerate(kfold.split(full_dataset)):
        print(f"\n{'='*60}")
        print(f"🔄 FOLD {fold + 1}/{n_splits}")
        print(f"{'='*60}")
        
        # Create subsets for current fold
        train_subset = Subset(full_dataset, train_idx)
        val_subset = Subset(full_dataset, val_idx)
        
        # Apply different transforms
        train_subset.dataset.transform = train_t
        val_subset.dataset.transform = val_t
        
        # Create data loaders
        train_loader = DataLoader(train_subset, batch_size=batch_size, shuffle=True, num_workers=4, pin_memory=True)
        val_loader = DataLoader(val_subset, batch_size=batch_size, shuffle=False, num_workers=4, pin_memory=True)
        
        # Create new model for each fold
        model = create_resnet50_model()
        
        # Train and validate current fold
        fold_metrics, fold_history = train_fold(
            model, train_loader, val_loader, fold + 1, epochs, lr
        )
        
        fold_results.append(fold_metrics)
        all_histories.extend(fold_history)
        
        print(f"\n✅ Fold {fold + 1} completed:")
        print(f"   AUC: {fold_metrics['auc']:.4f}, Acc: {fold_metrics['acc']:.3f}, "
              f"Sens: {fold_metrics['sens']:.3f}, Spec: {fold_metrics['spec']:.3f}")

    # ---------------- Cross Validation Results ----------------
    print(f"\n{'='*80}")
    print(f"🎯 {n_splits}-FOLD CROSS VALIDATION RESULTS - RESNET-50")
    print(f"{'='*80}")
    
    # Calculate average metrics across all folds
    avg_auc = np.mean([result['auc'] for result in fold_results])
    avg_acc = np.mean([result['acc'] for result in fold_results])
    avg_sens = np.mean([result['sens'] for result in fold_results])
    avg_spec = np.mean([result['spec'] for result in fold_results])
    
    std_auc = np.std([result['auc'] for result in fold_results])
    std_acc = np.std([result['acc'] for result in fold_results])
    std_sens = np.std([result['sens'] for result in fold_results])
    std_spec = np.std([result['spec'] for result in fold_results])
    
    print(f"\n📊 Average Performance across {n_splits} folds:")
    print(f"🏆 AUC:        {avg_auc:.4f} ± {std_auc:.4f}")
    print(f"🎯 Accuracy:   {avg_acc:.3f} ± {std_acc:.3f}")
    print(f"❤️  Sensitivity: {avg_sens:.3f} ± {std_sens:.3f}")
    print(f"🛡️  Specificity: {avg_spec:.3f} ± {std_spec:.3f}")
    
    print(f"\n📈 Individual Fold Results:")
    for i, result in enumerate(fold_results, 1):
        print(f"   Fold {i}: AUC={result['auc']:.4f}, Acc={result['acc']:.3f}, "
              f"Sens={result['sens']:.3f}, Spec={result['spec']:.3f}")
    
    # ---------------- Final Ensemble Evaluation ----------------
    print(f"\n{'='*60}")
    print(f"🤝 ENSEMBLE EVALUATION ACROSS ALL FOLDS")
    print(f"{'='*60}")
    
    # Create a test set from the entire dataset for final evaluation
    n_total = len(full_dataset)
    n_test = int(0.15 * n_total)  # 15% for final test
    n_train_val = n_total - n_test
    train_val_ds, test_ds = random_split(full_dataset, [n_train_val, n_test])
    test_ds.dataset.transform = val_t
    test_loader = DataLoader(test_ds, batch_size=batch_size, shuffle=False, num_workers=4)
    
    # Ensemble prediction using all fold models
    all_fold_probs = []
    
    for fold in range(1, n_splits + 1):
        model_path = f"Ai in Medicine - Neeraja and Ridhima/best_resnet50_fold{fold}_safe.pth"
        model = create_resnet50_model()
        
        if safe_load_model_state_dict(model_path, model):
            model.eval()
            fold_probs = []
            with torch.no_grad():
                for imgs, _ in test_loader:
                    imgs = imgs.to(device)
                    out = torch.sigmoid(model(imgs).squeeze(1)).cpu()
                    fold_probs.extend(out)
            all_fold_probs.append(fold_probs)
            print(f"✅ Fold {fold} loaded for ensemble prediction")
        else:
            print(f"❌ Could not load Fold {fold} for ensemble")
    
    if all_fold_probs:
        # Average predictions across all folds
        ensemble_probs = np.mean(np.array(all_fold_probs), axis=0)
        test_labels = [label for _, label in test_ds]
        
        ensemble_auc, ensemble_acc, ensemble_sens, ensemble_spec = compute_metrics(test_labels, ensemble_probs)
        
        print(f"\n🎯 ENSEMBLE TEST RESULTS:")
        print(f"🏆 AUC:          {ensemble_auc:.4f}")
        print(f"🎯 Accuracy:     {ensemble_acc:.3f}")
        print(f"❤️  Sensitivity:  {ensemble_sens:.3f}")
        print(f"🛡️  Specificity:  {ensemble_spec:.3f}")
    
    # Save cross-validation results
    results_dir = "Ai in Medicine - Neeraja and Ridhima"
    os.makedirs(results_dir, exist_ok=True)
    
    # Save results to file
    with open(os.path.join(results_dir, "resnet50_cross_validation_results.txt"), "w") as f:
        f.write(f"{n_splits}-Fold Cross Validation Results - ResNet-50\n")
        f.write("=" * 60 + "\n")
        f.write(f"Average AUC: {avg_auc:.4f} ± {std_auc:.4f}\n")
        f.write(f"Average Accuracy: {avg_acc:.3f} ± {std_acc:.3f}\n")
        f.write(f"Average Sensitivity: {avg_sens:.3f} ± {std_sens:.3f}\n")
        f.write(f"Average Specificity: {avg_spec:.3f} ± {std_spec:.3f}\n\n")
        
        if all_fold_probs:
            f.write(f"Ensemble Test Results:\n")
            f.write(f"AUC: {ensemble_auc:.4f}\n")
            f.write(f"Accuracy: {ensemble_acc:.3f}\n")
            f.write(f"Sensitivity: {ensemble_sens:.3f}\n")
            f.write(f"Specificity: {ensemble_spec:.3f}\n\n")
        
        f.write("Individual Fold Results:\n")
        for i, result in enumerate(fold_results, 1):
            f.write(f"Fold {i}: AUC={result['auc']:.4f}, Acc={result['acc']:.3f}, "
                   f"Sens={result['sens']:.3f}, Spec={result['spec']:.3f}\n")
        
        f.write(f"\nComparison with ResNet-18:\n")
        resnet18_auc = 0.8795
        resnet18_acc = 0.767
        resnet18_sens = 0.643
        resnet18_spec = 0.875
        
        f.write(f"AUC:          {resnet18_auc:.4f} → {avg_auc:.4f} ({'↑' if avg_auc > resnet18_auc else '↓'} {(avg_auc-resnet18_auc)*100:+.2f}%)\n")
        f.write(f"Accuracy:     {resnet18_acc:.3f} → {avg_acc:.3f} ({'↑' if avg_acc > resnet18_acc else '↓'} {(avg_acc-resnet18_acc)*100:+.2f}%)\n")
        f.write(f"Sensitivity:  {resnet18_sens:.3f} → {avg_sens:.3f} ({'↑' if avg_sens > resnet18_sens else '↓'} {(avg_sens-resnet18_sens)*100:+.2f}%)\n")
        f.write(f"Specificity:  {resnet18_spec:.3f} → {avg_spec:.3f} ({'↑' if avg_spec > resnet18_spec else '↓'} {(avg_spec-resnet18_spec)*100:+.2f}%)\n")
    
    print(f"\n💾 Results saved to: {os.path.join(results_dir, 'resnet50_cross_validation_results.txt')}")
    
    # Cleanup temporary directories
    try:
        shutil.rmtree(clean_root)
        print(f"🧹 Cleaned up temporary directory")
    except:
        pass


# -------------------------
if __name__ == "__main__":
    main()
