    print(f"  Sensitivity:  {cv_sens_mean:.3f} ± {np.std([result['sens'] for result in cv_results]):.3f}")
    print(f"  Specificity:  {cv_spec_mean:.3f} ± {np.std([result['spec'] for result in cv_results]):.3f}")
