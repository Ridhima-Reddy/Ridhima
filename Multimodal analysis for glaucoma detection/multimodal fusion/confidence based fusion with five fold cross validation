    # Create confidence-based fusion model
    print(f"\n🧪 INITIALIZING CONFIDENCE-BASED FUSION MODEL")
    model = ConfidenceBasedFusion(actual_num_features, STAGE1_MODEL_PATH, confidence_threshold=0.3)
