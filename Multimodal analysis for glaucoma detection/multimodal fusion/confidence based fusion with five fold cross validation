class MultimodalGlaucomaDataset(Dataset):
    """Dataset that combines fundus images and OCTA metrics"""
    def __init__(self, image_data_dir, octa_csv_path, transform=None):
        """
        Args:
            image_data_dir: Directory with fundus images (same as Stage 1)
            octa_csv_path: Path to blood flow.csv with OCTA metrics
            transform: Transformations for fundus images
        """
        self.image_data_dir = image_data_dir
        self.octa_data = pd.read_csv(octa_csv_path)
        self.transform = transform
        
        # Clean column names first
        self.octa_data = clean_column_names(self.octa_data)
        
        # Use flexible column matching to find the exact column names
        self.octa_features = self.find_octa_features()
        
        print("🔍 Verifying OCTA features exist...")
        for feature in self.octa_features:
            print(f"✅ Using: '{feature}'")
        
        if not self.octa_features:
            print("🚨 CRITICAL: No OCTA features found! Available columns:")
            for col in self.octa_data.columns[:20]:  # Show first 20 columns
                print(f"   - '{col}'")
            raise ValueError("No valid OCTA features found!")
        
        print(f"🎯 Final OCTA features: {self.octa_features}")
        
        # PROPER LABELING: Use folder-based labeling instead of hardcoded indices
        self.setup_proper_labeling()
        
        # Clean OCTA data - more robust handling
        print("🧹 Cleaning OCTA data...")
        for feature in self.octa_features:
            # Convert to numeric, coercing errors to NaN
            self.octa_data[feature] = clean_numeric_data(self.octa_data[feature])
            # Check for any remaining non-numeric values
            non_numeric_count = self.octa_data[feature].isna().sum()
            if non_numeric_count > 0:
                print(f"⚠️  Found {non_numeric_count} non-numeric values in '{feature}', converting to NaN")
        
        # Remove rows with missing OCTA data
        initial_count = len(self.octa_data)
        self.octa_data = self.octa_data.dropna(subset=self.octa_features)
        final_count = len(self.octa_data)
        removed_count = initial_count - final_count
        print(f"📊 Removed {removed_count} rows with missing data. Remaining: {final_count} rows")
        
        # Convert to float32 to ensure numeric consistency
        for feature in self.octa_features:
            self.octa_data[feature] = self.octa_data[feature].astype(np.float32)
        
        # Standardize OCTA features
        self.scaler = StandardScaler()
        octa_values = self.octa_data[self.octa_features].values
        self.octa_data[self.octa_features] = self.scaler.fit_transform(octa_values)
        
        print(f"✅ Multimodal dataset: {len(self.octa_data)} samples")
        
        # Get image paths - using folder-based matching
        self.setup_image_paths()
        
        # Store labels for stratified k-fold
        self.labels = self.octa_data['glaucoma'].values
    
    def setup_proper_labeling(self):
        """Set up proper glaucoma labels based on folder matching"""
        print("\n🏷️ Setting up proper glaucoma labels from folders...")
        
        # Get the actual image files from glaucoma and normal folders
        glaucoma_folder = os.path.join(self.image_data_dir, "Glaucoma")
        normal_folder = os.path.join(self.image_data_dir, "Normal")
        
        # Extract patient ID from image filenames (format: 1_OD.png, 190_OS.png, etc.)
        def extract_id_from_filename(filename):
            """Extract ID from filename like 1_OD.png -> 1"""
            return filename.split('_')[0]
        
        # Get glaucoma cases
        glaucoma_files = []
        if os.path.exists(glaucoma_folder):
            for file in os.listdir(glaucoma_folder):
                if file.endswith(('.png', '.jpg', '.jpeg')):
                    patient_id = extract_id_from_filename(file)
                    glaucoma_files.append(patient_id)
        
        # Get normal cases  
        normal_files = []
        if os.path.exists(normal_folder):
            for file in os.listdir(normal_folder):
                if file.endswith(('.png', '.jpg', '.jpeg')):
                    patient_id = extract_id_from_filename(file)
                    normal_files.append(patient_id)
        
        print(f"📁 Found {len(glaucoma_files)} glaucoma images")
        print(f"📁 Found {len(normal_files)} normal images")
        
        # Find the ID column in the CSV
        possible_id_columns = ['SNO', 'ID', 'Id', 'Patient', 'PatientID', 'Subject', 'SubjectID', 'No', 'Number']
        id_column = None
        
        for col in possible_id_columns:
            if col in self.octa_data.columns:
                id_column = col
                break
        
        # If no common ID column found, use the first column
        if id_column is None:
            id_column = self.octa_data.columns[0]
            print(f"⚠️  No standard ID column found, using first column: '{id_column}'")
        else:
            print(f"✅ Using ID column: '{id_column}'")
        
        # Convert ID column to string for matching
        self.octa_data['ID_str'] = self.octa_data[id_column].astype(str).str.strip()
        
        # Also strip any whitespace from the image file IDs
        glaucoma_files = [id.strip() for id in glaucoma_files]
        normal_files = [id.strip() for id in normal_files]
        
        # Create proper glaucoma labels
        self.octa_data['glaucoma'] = 0  # Initialize all as normal
        
        # Mark glaucoma cases
        glaucoma_mask = self.octa_data['ID_str'].isin(glaucoma_files)
        self.octa_data.loc[glaucoma_mask, 'glaucoma'] = 1
        
        # Mark normal cases
        normal_mask = self.octa_data['ID_str'].isin(normal_files)
        
        print(f"\n✅ Final label distribution:")
        print(f"   Glaucoma: {glaucoma_mask.sum()} cases")
        print(f"   Normal: {normal_mask.sum()} cases")
        print(f"   Unmatched: {len(self.octa_data) - (glaucoma_mask.sum() + normal_mask.sum())} cases")
        
        # Show some examples of matches
        if glaucoma_mask.sum() > 0:
            print(f"\n🔍 Glaucoma match examples:")
            glaucoma_samples = self.octa_data[glaucoma_mask].head(3)
            for _, row in glaucoma_samples.iterrows():
                print(f"   ID: '{row['ID_str']}' -> Glaucoma")
        
        if normal_mask.sum() > 0:
            print(f"🔍 Normal match examples:")
            normal_samples = self.octa_data[normal_mask].head(3)
            for _, row in normal_samples.iterrows():
                print(f"   ID: '{row['ID_str']}' -> Normal")
    
    def find_octa_features(self):
        """Find the actual column names with flexible matching"""
        target_features = [
            'I flux ONH',      # 1. I flux ONH
            'I per ONH',       # 2. I per ONH 
            'S per ONH',       # 3. S per ONH 
            'SS ONH/10',       # 4. SS ONH/10
            'S flux ONH',      # 5. S flux ONH
            '3x3_vsl_inner',   # 6. 3x3_vsl_inner
            'TOT flux ONH'     # 7. TOT flux ONH
        ]
        found_features = []
        
        for target in target_features:
            matched_col = find_matching_column(self.octa_data, target)
            if matched_col:
                found_features.append(matched_col)
            else:
                print(f"⚠️  Could not find close match for: '{target}'")
        
        return found_features
    
    def setup_image_paths(self):
        """Setup image paths based on folder structure and SNO matching"""
        self.image_paths = []
        
        # Map patient IDs to image paths
        for idx in range(len(self.octa_data)):
            patient_id = self.octa_data.iloc[idx]['ID_str']
            diagnosis = "glaucoma" if self.octa_data.iloc[idx]['glaucoma'] == 1 else "normal"
            
            # Try to find the corresponding image
            image_path = self.find_image_path(patient_id, diagnosis)
            if image_path:
                self.image_paths.append(image_path)
            else:
                self.image_paths.append(None)
        
        valid_images = sum(1 for path in self.image_paths if path is not None)
        print(f"   Found {valid_images}/{len(self.octa_data)} matching images")
    
    def find_image_path(self, patient_id, diagnosis):
        """Find image path based on patient ID and diagnosis"""
        # Define possible folder structures
        possible_folders = [
            os.path.join(self.image_data_dir, diagnosis),  # Subfolder structure
            self.image_data_dir  # Root folder
        ]
        
        # Try different naming conventions
        possible_patterns = [
            f"{patient_id}_*.jpg",
            f"{patient_id}_*.png", 
            f"{patient_id}_*.jpeg",
            f"{patient_id}.jpg",
            f"{patient_id}.png",
            f"{patient_id}.jpeg",
            f"image_{patient_id}.jpg",
            f"fundus_{patient_id}.png",
        ]
        
        for folder in possible_folders:
            if not os.path.exists(folder):
                continue
                
            for pattern in possible_patterns:
                # Use glob for pattern matching
                matches = glob.glob(os.path.join(folder, pattern))
                if matches:
                    return matches[0]  # Return first match
        
        return None
    
    def __len__(self):
        return len(self.octa_data)
    
    def __getitem__(self, idx):
        # Get OCTA metrics - ensure they're numeric
        octa_values = self.octa_data.iloc[idx][self.octa_features].values
        
        # Convert to numpy array and ensure float32
        octa_metrics = torch.FloatTensor(octa_values.astype(np.float32))
        
        # Get glaucoma label
        label = torch.tensor(self.octa_data.iloc[idx]['glaucoma'], dtype=torch.float32)
        
        # Get image
        image_path = self.image_paths[idx]
        if image_path and os.path.exists(image_path):
            image = Image.open(image_path).convert('RGB')
        else:
            # Create dummy image if not found
            image = Image.new('RGB', (224, 224), color='white')
        
        if self.transform:
            image = self.transform(image)
        
        return image, octa_metrics, label

# ------------------------- CONFIDENCE-BASED FUSION MODEL -------------------------

class ConfidenceBasedFusion(nn.Module):
    """
    Confidence-based fusion: Use OCTA only when image model is uncertain
    with learnable OCTA weight parameter
    """
    def __init__(self, num_octa_features, cnn_pretrained_path, confidence_threshold=0.3):
        super().__init__()
        
        self.confidence_threshold = confidence_threshold
        
        # Learnable OCTA weight parameter (initialized at 0.5)
        self.octa_weight = nn.Parameter(torch.tensor(0.5))
        
        # Image model (frozen)
        self.image_model = models.resnet18(pretrained=False)
        self.image_model.fc = nn.Sequential(
            nn.Dropout(0.2),
            nn.Linear(self.image_model.fc.in_features, 1)
        )
        
        # Load pre-trained weights
        checkpoint = torch.load(cnn_pretrained_path, map_location='cpu')
        self.image_model.load_state_dict(checkpoint)
        
        # Freeze the image model
        for param in self.image_model.parameters():
            param.requires_grad = False
        
        # OCTA model (trainable)
        self.octa_model = nn.Sequential(
            nn.Linear(num_octa_features, 128),
            nn.BatchNorm1d(128),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(128, 64),
            nn.BatchNorm1d(64),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(64, 32),
            nn.ReLU(),
            nn.Linear(32, 1)
        )
        
        print(f"✅ Confidence-Based Fusion:")
        print(f"   - Confidence threshold: {confidence_threshold}")
        print(f"   - OCTA weight: Learnable parameter (initial: {self.octa_weight.item():.3f})")
        print(f"   - Image model: ResNet18 (frozen)")
        print(f"   - OCTA model: {num_octa_features} -> 128 -> 64 -> 32 -> 1")
    
    def forward(self, images, octa_metrics):
        # Get image predictions (frozen)
        with torch.no_grad():
            image_logits = self.image_model(images).squeeze(1)
            image_probs = torch.sigmoid(image_logits)
        
        # Get OCTA predictions (trainable)
        octa_logits = self.octa_model(octa_metrics).squeeze(1)
        octa_probs = torch.sigmoid(octa_logits)
        
        # Create confidence mask: 1 for uncertain cases, 0 for confident cases
        confidence_mask = ((image_probs >= self.confidence_threshold) & 
                          (image_probs <= (1 - self.confidence_threshold))).float()
        
        # Apply sigmoid to ensure OCTA weight is between 0 and 1
        octa_weight_sigmoid = torch.sigmoid(self.octa_weight)
        
        # For confident cases, use image prediction
        # For uncertain cases, blend image and OCTA predictions
        final_probs = image_probs * (1 - confidence_mask) + \
                     (image_probs * (1 - octa_weight_sigmoid) + octa_probs * octa_weight_sigmoid) * confidence_mask
        
        # Convert back to logits for loss calculation
        final_logits = torch.log(final_probs / (1 - final_probs + 1e-8))
        
        return final_logits, octa_weight_sigmoid

# ------------------------- TRAINING AND EVALUATION -------------------------

def compute_metrics(y_true, y_probs, threshold=0.5):
    y_true = torch.tensor(y_true).numpy()
    y_probs = torch.tensor(y_probs).numpy()
    auc = roc_auc_score(y_true, y_probs)
    y_pred = (y_probs >= threshold).astype(int)
    acc = accuracy_score(y_true, y_pred)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    sens = tp / (tp + fn)
    spec = tn / (tn + fp)
    return auc, acc, sens, spec

def train_confidence_fusion(model, train_loader, val_loader, num_epochs=50, lr=1e-4, fold=None):
    """Train confidence-based fusion with learnable OCTA weight"""
    if fold:
        print(f"\n🚀 TRAINING FOLD {fold}")
    else:
        print(f"\n🚀 TRAINING CONFIDENCE-BASED FUSION")
    print("="*60)
    print(f"📊 Batch size: 32")
    print(f"📊 Epochs: {num_epochs}")
    print(f"📊 Learning rate: {lr}")
    
    criterion = nn.BCEWithLogitsLoss()
    optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=1e-4)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=num_epochs)
    
    best_auc = 0.0
    patience_counter = 0
    patience = 15  # Increased patience for 50 epochs
    
    for epoch in range(1, num_epochs + 1):
        # Training
        model.train()
        total_loss = 0
        
        for images, octa_metrics, labels in tqdm(train_loader, desc=f"Epoch {epoch}/{num_epochs}"):
            images = images.to(device)
            octa_metrics = octa_metrics.to(device)
            labels = labels.to(device)
            
            optimizer.zero_grad()
            outputs, current_octa_weight = model(images, octa_metrics)
            loss = criterion(outputs, labels)
            loss.backward()
            optimizer.step()
            
            total_loss += loss.item() * images.size(0)
        
        avg_loss = total_loss / len(train_loader.dataset)
        
        # Validation
        model.eval()
        all_probs, all_labels = [], []
        current_octa_weight = 0.0
        
        with torch.no_grad():
            for images, octa_metrics, labels in val_loader:
                images = images.to(device)
                octa_metrics = octa_metrics.to(device)
                labels = labels.to(device)
                
                outputs, octa_weight = model(images, octa_metrics)
                probs = torch.sigmoid(outputs).cpu()
                all_probs.extend(probs)
                all_labels.extend(labels.cpu())
                current_octa_weight = octa_weight.item()  # Get the current OCTA weight
        
        auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
        current_lr = optimizer.param_groups[0]['lr']
        scheduler.step()
        
        if fold:
            print(f"Fold {fold} Epoch {epoch:2d} | Loss: {avg_loss:.4f} | AUC: {auc:.4f} | Acc: {acc:.3f} | Sens: {sens:.3f} | Spec: {spec:.3f}")
            print(f"                    | LR: {current_lr:.2e} | OCTA Weight: {current_octa_weight:.3f}")
        else:
            print(f"Epoch {epoch:2d}/{num_epochs} | Loss: {avg_loss:.4f} | AUC: {auc:.4f} | Acc: {acc:.3f} | Sens: {sens:.3f} | Spec: {spec:.3f}")
            print(f"                    | LR: {current_lr:.2e} | OCTA Weight: {current_octa_weight:.3f}")

        # Early stopping
        if auc > best_auc:
            best_auc = auc
            patience_counter = 0
            if fold:
                torch.save(model.state_dict(), f"Ai in Medicine - Neeraja and Ridhima/best_confidence_fusion_fold_{fold}.pth")
                print(f"✅ Saved best fold {fold} model (AUC: {auc:.4f}, OCTA Weight: {current_octa_weight:.3f})")
            else:
                torch.save(model.state_dict(), "Ai in Medicine - Neeraja and Ridhima/best_confidence_fusion.pth")
                print(f"✅ Saved best model (AUC: {auc:.4f}, OCTA Weight: {current_octa_weight:.3f})")
        else:
            patience_counter += 1
            if patience_counter >= patience:
                print(f"🛑 Early stopping at epoch {epoch}")
                break
    
    return best_auc

def evaluate_multimodal_model(model, test_loader, fold=None):
    """Evaluate the model and return OCTA weight"""
    model.eval()
    all_probs, all_labels = [], []
    final_octa_weight = 0.0
    
    with torch.no_grad():
        for images, octa_metrics, labels in test_loader:
            images = images.to(device)
            octa_metrics = octa_metrics.to(device)
            labels = labels.to(device)
            outputs, octa_weight = model(images, octa_metrics)
            probs = torch.sigmoid(outputs).cpu()
            all_probs.extend(probs)
            all_labels.extend(labels.cpu())
            final_octa_weight = octa_weight.item()
    
    auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
    
    if fold:
        print(f"🎯 FOLD {fold} TEST RESULTS:")
    else:
        print(f"🎯 TEST RESULTS:")
    
    print(f"🏆 AUC:          {auc:.4f}")
    print(f"🎯 Accuracy:     {acc:.3f}")
    print(f"❤️  Sensitivity:  {sens:.3f}")
    print(f"🛡️  Specificity:  {spec:.3f}")
    print(f"⚖️  Final OCTA Weight: {final_octa_weight:.3f}")
    
    return {'auc': auc, 'acc': acc, 'sens': sens, 'spec': spec, 'octa_weight': final_octa_weight}

def run_five_fold_cross_validation(full_dataset, num_octa_features, cnn_pretrained_path, num_epochs=50, lr=1e-4):
    """Run 5-fold cross-validation with confidence-based fusion"""
    print(f"\n🎯 5-FOLD CROSS VALIDATION FOR CONFIDENCE-BASED FUSION")
    print("=" * 70)
    
    # Setup transforms
    train_transform = T.Compose([
        T.Resize((224, 224)),
        T.RandomHorizontalFlip(p=0.5),
        T.RandomRotation(degrees=10),
        T.RandomAffine(degrees=0, translate=(0.1, 0.1)),
        T.ColorJitter(brightness=0.2, contrast=0.2),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    
    val_transform = T.Compose([
        T.Resize((224, 224)),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    
    # Initialize stratified k-fold
    skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
    
    fold_results = []
    fold_octa_weights = []
    
    for fold, (train_idx, val_idx) in enumerate(skf.split(range(len(full_dataset)), full_dataset.labels)):
        print(f"\n{'='*60}")
        print(f"🔄 FOLD {fold + 1}/5")
        print(f"{'='*60}")
        
        # Create datasets for this fold
        train_dataset = Subset(full_dataset, train_idx)
        val_dataset = Subset(full_dataset, val_idx)
        
        # Apply transforms
        train_dataset.dataset.transform = train_transform
        val_dataset.dataset.transform = val_transform
        
        # Create data loaders with batch size 32
        train_loader = DataLoader(train_dataset, batch_size=32, shuffle=True, num_workers=4, pin_memory=True)
        val_loader = DataLoader(val_dataset, batch_size=32, shuffle=False, num_workers=4, pin_memory=True)
        
        # Create model for this fold
        model = ConfidenceBasedFusion(
            num_octa_features=num_octa_features,
            cnn_pretrained_path=cnn_pretrained_path,
            confidence_threshold=0.3
        ).to(device)
        
        # Train model for this fold
        best_fold_auc = train_confidence_fusion(model, train_loader, val_loader, num_epochs, lr, fold=fold+1)
        
        # Load best model and evaluate on validation set
        model.load_state_dict(torch.load(f"Ai in Medicine - Neeraja and Ridhima/best_confidence_fusion_fold_{fold+1}.pth"))
        fold_metrics = evaluate_multimodal_model(model, val_loader, fold=fold+1)
        
        # Store results
        fold_results.append(fold_metrics)
        fold_octa_weights.append(fold_metrics['octa_weight'])
        
        print(f"✅ Fold {fold+1} completed | AUC: {fold_metrics['auc']:.4f} | OCTA Weight: {fold_metrics['octa_weight']:.3f}")
    
    # Cross-validation results summary
    print(f"\n{'='*70}")
    print(f"📊 5-FOLD CROSS-VALIDATION RESULTS SUMMARY")
    print(f"{'='*70}")
    
    # Extract metrics for each fold
    aucs = [result['auc'] for result in fold_results]
    accs = [result['acc'] for result in fold_results]
    senss = [result['sens'] for result in fold_results]
    specs = [result['spec'] for result in fold_results]
    octa_weights = [result['octa_weight'] for result in fold_results]
    
    print(f"\n📈 AUC:")
    print(f"  Fold AUCs: {[f'{auc:.4f}' for auc in aucs]}")
    print(f"  Mean AUC:  {np.mean(aucs):.4f} ± {np.std(aucs):.4f}")
    
    print(f"\n🎯 Accuracy:")
    print(f"  Fold Accs: {[f'{acc:.3f}' for acc in accs]}")
    print(f"  Mean Acc:  {np.mean(accs):.3f} ± {np.std(accs):.3f}")
    
    print(f"\n❤️  Sensitivity:")
    print(f"  Fold Sens: {[f'{sens:.3f}' for sens in senss]}")
    print(f"  Mean Sens: {np.mean(senss):.3f} ± {np.std(senss):.3f}")
    
    print(f"\n🛡️  Specificity:")
    print(f"  Fold Spec: {[f'{spec:.3f}' for spec in specs]}")
    print(f"  Mean Spec: {np.mean(specs):.3f} ± {np.std(specs):.3f}")
    
    print(f"\n⚖️  OCTA Weights:")
    print(f"  Fold Weights: {[f'{w:.3f}' for w in octa_weights]}")
    print(f"  Mean Weight:  {np.mean(octa_weights):.3f} ± {np.std(octa_weights):.3f}")
    
    print(f"\n🏆 OVERALL PERFORMANCE:")
    print(f"  AUC:          {np.mean(aucs):.4f} ± {np.std(aucs):.4f}")
    print(f"  Accuracy:     {np.mean(accs):.3f} ± {np.std(accs):.3f}")
    print(f"  Sensitivity:  {np.mean(senss):.3f} ± {np.std(senss):.3f}")
    print(f"  Specificity:  {np.mean(specs):.3f} ± {np.std(specs):.3f}")
    print(f"  OCTA Weight:  {np.mean(octa_weights):.3f} ± {np.std(octa_weights):.3f}")
    
    return fold_results

def compare_with_stage1(multimodal_results, stage1_auc=0.9464):
    if isinstance(multimodal_results, dict):
        # Single test result
        multimodal_auc = multimodal_results['auc']
        octa_weight = multimodal_results['octa_weight']
    else:
        # Cross-validation results (list of folds)
        multimodal_auc = np.mean([result['auc'] for result in multimodal_results])
        octa_weight = np.mean([result['octa_weight'] for result in multimodal_results])
    
    improvement = multimodal_auc - stage1_auc
    
    print(f"\n📈 COMPARISON WITH STAGE 1:")
    print(f"Stage 1 (Fundus-only):  AUC = {stage1_auc:.4f}")
    print(f"Stage 3 (Multimodal):   AUC = {multimodal_auc:.4f}")
    print(f"OCTA Weight:            {octa_weight:.3f}")
    print(f"Improvement:            {improvement:+.4f} ({improvement*100:+.2f}%)")
    
    if improvement > 0:
        print("✅ Multimodal fusion IMPROVES performance! 🎉")
    else:
        print("⚠️  OCTA features not providing additional value")

