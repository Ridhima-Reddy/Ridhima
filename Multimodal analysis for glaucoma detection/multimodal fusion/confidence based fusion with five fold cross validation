        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    
    # Apply transforms to full dataset
    full_dataset.transform = train_transform
    
    # Data split (70% train, 15% val, 15% test)
