# ------------------------- MULTIMODAL DATASET -------------------------

class MultimodalGlaucomaDataset(Dataset):
    """Dataset that combines fundus images and OCTA metrics with proper SNO-based labeling"""
    def __init__(self, image_data_dir, octa_csv_path, transform=None):
        self.image_data_dir = image_data_dir
        self.octa_data = pd.read_csv(octa_csv_path)
        self.transform = transform
        
        # Use the 7 selected OCTA features
        self.octa_features = [
            'I flux ONH',      # 1. I flux ONH
            'I per ONH',       # 2. I per ONH 
            'S per ONH',       # 3. S per ONH 
            'SS ONH/10',       # 4. SS ONH/10
            'S flux ONH',      # 5. S flux ONH
            '3x3_vsl_inner',   # 6. 3x3_vsl_inner
            'TOT flux ONH'     # 7. TOT flux ONH
        ]
        
        print("🔍 Using OCTA features:", self.octa_features)
        
        # Clean column names first
        self.octa_data.columns = [col.strip() for col in self.octa_data.columns]
        
        # Find the actual column names with flexible matching
        self.octa_features = self.find_actual_octa_features()
        
        print("✅ Final OCTA features being used:")
        for feature in self.octa_features:
            print(f"   - '{feature}'")
        
        # Setup proper labeling based on SNO and folder matching
        self.setup_proper_labeling()
        
        # Clean OCTA data
        print("🧹 Cleaning OCTA data...")
        for feature in self.octa_features:
            self.octa_data[feature] = pd.to_numeric(self.octa_data[feature], errors='coerce')
        
        # Remove rows with missing data
        initial_count = len(self.octa_data)
        self.octa_data = self.octa_data.dropna(subset=self.octa_features)
        final_count = len(self.octa_data)
        print(f"📊 Removed {initial_count - final_count} rows. Remaining: {final_count}")
        
        # Convert to float32 and standardize
        for feature in self.octa_features:
            self.octa_data[feature] = self.octa_data[feature].astype(np.float32)
        
        self.scaler = StandardScaler()
        octa_values = self.octa_data[self.octa_features].values
        self.octa_data[self.octa_features] = self.scaler.fit_transform(octa_values)
        
        # Setup image paths with proper SNO-based matching
        self.setup_image_paths()
        
        # Store labels for stratified k-fold
        self.labels = self.octa_data['glaucoma'].values
    
    def find_actual_octa_features(self):
        """Find the actual column names with flexible matching"""
        target_features = [
            'I flux ONH',      # 1. I flux ONH
            'I per ONH',       # 2. I per ONH 
            'S per ONH',       # 3. S per ONH 
            'SS ONH/10',       # 4. SS ONH/10
            'S flux ONH',      # 5. S flux ONH
            '3x3_vsl_inner',   # 6. 3x3_vsl_inner
            'TOT flux ONH'     # 7. TOT flux ONH
        ]
        
        found_features = []
        available_columns = list(self.octa_data.columns)
        
        for target in target_features:
            # Try exact match
            if target in available_columns:
                found_features.append(target)
                continue
            
            # Try case-insensitive and whitespace-insensitive matching
            target_clean = target.strip().lower().replace(' ', '')
            for col in available_columns:
                col_clean = col.strip().lower().replace(' ', '')
                if target_clean == col_clean:
                    found_features.append(col)
                    break
            else:
                # Try partial matching
                for col in available_columns:
                    if target.strip().lower() in col.lower() or col.lower() in target.strip().lower():
                        found_features.append(col)
                        break
                else:
                    print(f"⚠️  Could not find: '{target}'")
        
        return found_features
    
    def setup_proper_labeling(self):
        """Set up proper glaucoma labels based on SNO matching with image folders"""
        print("\n🏷️ Setting up proper glaucoma labels from folders...")
        
        # Get the actual image files from glaucoma and normal folders
        glaucoma_folder = os.path.join(self.image_data_dir, "Glaucoma")
        normal_folder = os.path.join(self.image_data_dir, "Normal")
        
        # Extract SNO from image filenames (format: 1_OD.png, 190_OS.png, etc.)
        def extract_sno_from_filename(filename):
            """Extract SNO from filename like 1_OD.png -> 1"""
            return filename.split('_')[0]
        
        # Get glaucoma cases
        glaucoma_files = []
        if os.path.exists(glaucoma_folder):
            for file in os.listdir(glaucoma_folder):
                if file.endswith(('.png', '.jpg', '.jpeg')):
                    sno = extract_sno_from_filename(file)
                    glaucoma_files.append(sno)
        
        # Get normal cases  
        normal_files = []
        if os.path.exists(normal_folder):
            for file in os.listdir(normal_folder):
                if file.endswith(('.png', '.jpg', '.jpeg')):
                    sno = extract_sno_from_filename(file)
                    normal_files.append(sno)
        
        print(f"📁 Found {len(glaucoma_files)} glaucoma images")
        print(f"📁 Found {len(normal_files)} normal images")
        
        # Find the SNO column in the CSV
        sno_column = None
        possible_sno_columns = ['SNO', 'ID', 'Id', 'Patient', 'PatientID', 'Subject', 'SubjectID', 'No', 'Number']
        
        for col in possible_sno_columns:
            if col in self.octa_data.columns:
                sno_column = col
                break
        
        # If no SNO column found, use the first column
        if sno_column is None:
            sno_column = self.octa_data.columns[0]
            print(f"⚠️  No SNO column found, using first column: '{sno_column}'")
        else:
            print(f"✅ Using SNO column: '{sno_column}'")
        
        # Convert SNO column to string for matching
        self.octa_data['SNO_str'] = self.octa_data[sno_column].astype(str).str.strip()
        
        # Also strip any whitespace from the image file SNOs
        glaucoma_files = [sno.strip() for sno in glaucoma_files]
        normal_files = [sno.strip() for sno in normal_files]
        
        # Create proper glaucoma labels
        self.octa_data['glaucoma'] = 0  # Initialize all as normal
        
        # Mark glaucoma cases
        glaucoma_mask = self.octa_data['SNO_str'].isin(glaucoma_files)
        self.octa_data.loc[glaucoma_mask, 'glaucoma'] = 1
        
        # Mark normal cases
        normal_mask = self.octa_data['SNO_str'].isin(normal_files)
        
        print(f"\n✅ Final label distribution:")
        print(f"   Glaucoma: {glaucoma_mask.sum()} cases")
        print(f"   Normal: {normal_mask.sum()} cases")
        print(f"   Unmatched: {len(self.octa_data) - (glaucoma_mask.sum() + normal_mask.sum())} cases")
        
        # Show some examples of matches
        if glaucoma_mask.sum() > 0:
            print(f"\n🔍 Glaucoma match examples:")
            glaucoma_samples = self.octa_data[glaucoma_mask].head(3)
            for _, row in glaucoma_samples.iterrows():
                print(f"   SNO: '{row['SNO_str']}' -> Glaucoma")
        
        if normal_mask.sum() > 0:
            print(f"🔍 Normal match examples:")
            normal_samples = self.octa_data[normal_mask].head(3)
            for _, row in normal_samples.iterrows():
                print(f"   SNO: '{row['SNO_str']}' -> Normal")
    
    def setup_image_paths(self):
        """Find images based on SNO matching with glaucoma/normal folders"""
        self.image_paths = []
        
        for idx in range(len(self.octa_data)):
            sno = self.octa_data.iloc[idx]['SNO_str']
            diagnosis = "glaucoma" if self.octa_data.iloc[idx]['glaucoma'] == 1 else "normal"
            
            # Try to find the corresponding image
            image_path = self.find_image_path(sno, diagnosis)
            self.image_paths.append(image_path)
        
        valid_images = sum(1 for path in self.image_paths if path is not None)
        print(f"📷 Found {valid_images}/{len(self.octa_data)} matching images")
        
        # Debug: show first few found images
        if valid_images > 0:
            print("Sample found images:")
            for i, path in enumerate(self.image_paths[:5]):
                if path:
                    print(f"  {i+1}. {os.path.basename(path)}")
    
    def find_image_path(self, sno, diagnosis):
        """Find image path based on SNO and diagnosis"""
        # Define possible folder structures
        possible_folders = [
            os.path.join(self.image_data_dir, diagnosis),  # Subfolder structure
            self.image_data_dir  # Root folder
        ]
        
        # Try different naming conventions
        possible_patterns = [
            f"{sno}_*.jpg",
            f"{sno}_*.png", 
            f"{sno}_*.jpeg",
            f"{sno}.jpg",
            f"{sno}.png",
            f"{sno}.jpeg",
            f"image_{sno}.jpg",
            f"fundus_{sno}.png",
        ]
        
        for folder in possible_folders:
            if not os.path.exists(folder):
                continue
                
            for pattern in possible_patterns:
                # Use glob for pattern matching
                matches = glob.glob(os.path.join(folder, pattern))
                if matches:
                    return matches[0]  # Return first match
        
        return None
    
    def __len__(self):
        return len(self.octa_data)
    
    def __getitem__(self, idx):
        # Get OCTA metrics
        octa_values = self.octa_data.iloc[idx][self.octa_features].values
        octa_metrics = torch.FloatTensor(octa_values.astype(np.float32))
        
        # Get glaucoma label
        label = torch.tensor(self.octa_data.iloc[idx]['glaucoma'], dtype=torch.float32)
        
        # Get image
        image_path = self.image_paths[idx]
        if image_path and os.path.exists(image_path):
            try:
                image = Image.open(image_path).convert('RGB')
            except:
                image = Image.new('RGB', (224, 224), color='white')
        else:
            # Create a proper dummy image that looks like fundus
            image = Image.new('RGB', (224, 224), color=(30, 30, 60))  # Dark blue-ish like fundus
        
        if self.transform:
            image = self.transform(image)
        
        return image, octa_metrics, label

# ------------------------- HYBRID DECISION MODEL -------------------------

class HybridDecisionModel(nn.Module):
    """
    Make separate decisions from images and OCTA, then combine
    """
    def __init__(self, num_octa_features, cnn_pretrained_path):
        super().__init__()
        
        # Image model
        self.image_model = models.resnet18(pretrained=False)
        self.image_model.fc = nn.Sequential(
            nn.Dropout(0.2),
            nn.Linear(self.image_model.fc.in_features, 1)
        )
        
        checkpoint = torch.load(cnn_pretrained_path, map_location='cpu')
        self.image_model.load_state_dict(checkpoint)
        
        # OCTA model
        self.octa_model = nn.Sequential(
            nn.Linear(num_octa_features, 128),
            nn.BatchNorm1d(128),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(128, 64),
            nn.BatchNorm1d(64),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(64, 32),
            nn.ReLU(),
            nn.Linear(32, 1)
        )
        
        # Final decision combiner
        self.combiner = nn.Linear(2, 1)  # Combine image and OCTA logits
        
        print(f"✅ Hybrid Decision Model:")
        print(f"   - Image model: ResNet18 (pre-trained)")
        print(f"   - OCTA model: {num_octa_features} -> 128 -> 64 -> 32 -> 1")
        print(f"   - Learn to combine both decisions")
    
    def forward(self, images, octa_metrics):
        # Get image prediction
        image_logits = self.image_model(images).squeeze(1)
        
        # Get OCTA prediction  
        octa_logits = self.octa_model(octa_metrics).squeeze(1)
        
        # Combine decisions
        combined = torch.stack([image_logits, octa_logits], dim=1)
        final_logits = self.combiner(combined).squeeze(1)
        
        return final_logits

# ------------------------- TRAINING AND EVALUATION -------------------------

def compute_metrics(y_true, y_probs, threshold=0.5):
    y_true = torch.tensor(y_true).numpy()
    y_probs = torch.tensor(y_probs).numpy()
    auc = roc_auc_score(y_true, y_probs)
    y_pred = (y_probs >= threshold).astype(int)
    acc = accuracy_score(y_true, y_pred)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    sens = tp / (tp + fn) if (tp + fn) > 0 else 0
    spec = tn / (tn + fp) if (tn + fp) > 0 else 0
    return auc, acc, sens, spec

def train_model(model, train_loader, val_loader, num_epochs=50, lr=1e-4, fold=None):
    """Generic training function - FIXED to return only best_auc"""
    if fold:
        print(f"\n🚀 TRAINING FOLD {fold}")
    else:
        print(f"\n🚀 TRAINING HYBRID DECISION MODEL")
    print("="*60)
    print(f"📊 Epochs: {num_epochs}")
    print(f"📊 Learning rate: {lr}")
    print(f"📊 Batch size: 32")
    
    criterion = nn.BCEWithLogitsLoss()
    optimizer = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=1e-4)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=num_epochs)
    
    best_auc = 0.0
    patience_counter = 0
    patience = 15
    
    for epoch in range(1, num_epochs + 1):
        # Training
        model.train()
        total_loss = 0
        
        for images, octa_metrics, labels in tqdm(train_loader, desc=f"Epoch {epoch}/{num_epochs}"):
            images = images.to(device)
            octa_metrics = octa_metrics.to(device)
            labels = labels.to(device)
            
            optimizer.zero_grad()
            outputs = model(images, octa_metrics)
            loss = criterion(outputs, labels)
            loss.backward()
            optimizer.step()
            
            total_loss += loss.item() * labels.size(0)
        
        avg_loss = total_loss / len(train_loader.dataset)
        
        # Validation
        model.eval()
        all_probs, all_labels = [], []
        with torch.no_grad():
            for images, octa_metrics, labels in val_loader:
                images = images.to(device)
                octa_metrics = octa_metrics.to(device)
                labels = labels.to(device)
                outputs = model(images, octa_metrics)
                
                probs = torch.sigmoid(outputs).cpu()
                all_probs.extend(probs)
                all_labels.extend(labels.cpu())
        
        auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
        current_lr = optimizer.param_groups[0]['lr']
        scheduler.step()
        
        if fold:
            print(f"Fold {fold} Epoch {epoch:2d} | Loss: {avg_loss:.4f} | AUC: {auc:.4f} | Acc: {acc:.3f} | Sens: {sens:.3f} | Spec: {spec:.3f} | LR: {current_lr:.2e}")
        else:
            print(f"Epoch {epoch:2d} | Loss: {avg_loss:.4f} | AUC: {auc:.4f} | Acc: {acc:.3f} | Sens: {sens:.3f} | Spec: {spec:.3f} | LR: {current_lr:.2e}")

        # Early stopping and save best model
        if auc > best_auc:
            best_auc = auc
            patience_counter = 0
            if fold:
                torch.save(model.state_dict(), f"Ai in Medicine - Neeraja and Ridhima/best_hybrid_fold_{fold}.pth")
                print(f"✅ Saved best fold {fold} model (AUC: {auc:.4f})")
            else:
                torch.save(model.state_dict(), "Ai in Medicine - Neeraja and Ridhima/best_hybrid.pth")
                print(f"✅ Saved best model (AUC: {auc:.4f})")
        else:
            patience_counter += 1
            if patience_counter >= patience:
                print(f"🛑 Early stopping at epoch {epoch}")
                break
    
    return best_auc  # FIXED: Return only best_auc, not both best_auc and path

def evaluate_model(model, test_loader, fold=None):
    model.eval()
    all_probs, all_labels = [], []
    with torch.no_grad():
        for images, octa_metrics, labels in test_loader:
            images = images.to(device)
            octa_metrics = octa_metrics.to(device)
            labels = labels.to(device)
            outputs = model(images, octa_metrics)
            
            probs = torch.sigmoid(outputs).cpu()
            all_probs.extend(probs)
            all_labels.extend(labels.cpu())
    
    auc, acc, sens, spec = compute_metrics(all_labels, all_probs)
    
    if fold:
        print(f"🎯 FOLD {fold} VALIDATION RESULTS:")
    else:
        print(f"🎯 TEST RESULTS:")
    
    print(f"🏆 AUC:          {auc:.4f}")
    print(f"🎯 Accuracy:     {acc:.3f}")
    print(f"❤️  Sensitivity:  {sens:.3f}")
    print(f"🛡️  Specificity:  {spec:.3f}")
    
    return {'auc': auc, 'acc': acc, 'sens': sens, 'spec': spec}

# ------------------------- 5-FOLD CROSS VALIDATION -------------------------

def run_five_fold_cross_validation(full_dataset, num_octa_features, cnn_pretrained_path, num_epochs=50, lr=1e-4):
    """Run 5-fold cross-validation with Hybrid Decision Model"""
    print(f"\n🎯 5-FOLD CROSS VALIDATION FOR HYBRID DECISION MODEL")
    print("=" * 70)
    
    # Setup transforms
    train_transform = T.Compose([
        T.Resize((224, 224)),
        T.RandomHorizontalFlip(p=0.5),
        T.RandomRotation(degrees=10),
        T.RandomAffine(degrees=0, translate=(0.1, 0.1)),
        T.ColorJitter(brightness=0.2, contrast=0.2),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    
    val_transform = T.Compose([
        T.Resize((224, 224)),
        T.ToTensor(),
        T.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]),
    ])
    
    # Initialize stratified k-fold
    skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
    
    fold_results = []
    
    for fold, (train_idx, val_idx) in enumerate(skf.split(range(len(full_dataset)), full_dataset.labels)):
        print(f"\n{'='*60}")
        print(f"🔄 FOLD {fold + 1}/5")
        print(f"{'='*60}")
        
        # Create datasets for this fold
        train_dataset = Subset(full_dataset, train_idx)
        val_dataset = Subset(full_dataset, val_idx)
        
        # Apply transforms
        train_dataset.dataset.transform = train_transform
        val_dataset.dataset.transform = val_transform
        
        # Create data loaders with batch size 32
        train_loader = DataLoader(train_dataset, batch_size=32, shuffle=True, num_workers=4, pin_memory=True)
        val_loader = DataLoader(val_dataset, batch_size=32, shuffle=False, num_workers=4, pin_memory=True)
        
        # Create model for this fold
        model = HybridDecisionModel(
            num_octa_features=num_octa_features,
            cnn_pretrained_path=cnn_pretrained_path
        ).to(device)
        
        # Train model for this fold
        best_fold_auc = train_model(model, train_loader, val_loader, num_epochs, lr, fold=fold+1)
        
        # Load best model and evaluate on validation set
        model.load_state_dict(torch.load(f"Ai in Medicine - Neeraja and Ridhima/best_hybrid_fold_{fold+1}.pth"))
        fold_metrics = evaluate_model(model, val_loader, fold=fold+1)
        
        # Store results
        fold_results.append(fold_metrics)
        
        print(f"✅ Fold {fold+1} completed | AUC: {fold_metrics['auc']:.4f} | Acc: {fold_metrics['acc']:.3f}")
    
    # Cross-validation results summary
    print(f"\n{'='*70}")
    print(f"📊 5-FOLD CROSS-VALIDATION RESULTS SUMMARY")
    print(f"{'='*70}")
    
    # Extract metrics for each fold
    aucs = [result['auc'] for result in fold_results]
    accs = [result['acc'] for result in fold_results]
    senss = [result['sens'] for result in fold_results]
    specs = [result['spec'] for result in fold_results]
    
    print(f"\n📈 AUC:")
    print(f"  Fold AUCs: {[f'{auc:.4f}' for auc in aucs]}")
    print(f"  Mean AUC:  {np.mean(aucs):.4f} ± {np.std(aucs):.4f}")
    
    print(f"\n🎯 Accuracy:")
    print(f"  Fold Accs: {[f'{acc:.3f}' for acc in accs]}")
    print(f"  Mean Acc:  {np.mean(accs):.3f} ± {np.std(accs):.3f}")
    
    print(f"\n❤️  Sensitivity:")
    print(f"  Fold Sens: {[f'{sens:.3f}' for sens in senss]}")
    print(f"  Mean Sens: {np.mean(senss):.3f} ± {np.std(senss):.3f}")
    
    print(f"\n🛡️  Specificity:")
    print(f"  Fold Spec: {[f'{spec:.3f}' for spec in specs]}")
    print(f"  Mean Spec: {np.mean(specs):.3f} ± {np.std(specs):.3f}")
    
    print(f"\n🏆 OVERALL PERFORMANCE:")
    print(f"  AUC:          {np.mean(aucs):.4f} ± {np.std(aucs):.4f}")
    print(f"  Accuracy:     {np.mean(accs):.3f} ± {np.std(accs):.3f}")
    print(f"  Sensitivity:  {np.mean(senss):.3f} ± {np.std(senss):.3f}")
    print(f"  Specificity:  {np.mean(specs):.3f} ± {np.std(specs):.3f}")
    
    return fold_results

def compare_with_stage1(multimodal_results, stage1_auc=0.9464, stage1_spec=0.750):
    if isinstance(multimodal_results, dict):
        # Single test result
        multimodal_auc = multimodal_results['auc']
        multimodal_spec = multimodal_results['spec']
    else:
        # Cross-validation results (list of folds)
        multimodal_auc = np.mean([result['auc'] for result in multimodal_results])
        multimodal_spec = np.mean([result['spec'] for result in multimodal_results])
    
    auc_improvement = multimodal_auc - stage1_auc
    spec_improvement = multimodal_spec - stage1_spec
    
    print(f"\n📈 COMPARISON WITH STAGE 1:")
    print(f"Stage 1 (Fundus-only):  AUC = {stage1_auc:.4f}, Spec = {stage1_spec:.3f}")
    print(f"Stage 3 (Hybrid):       AUC = {multimodal_auc:.4f}, Spec = {multimodal_spec:.3f}")
    print(f"AUC Improvement:        {auc_improvement:+.4f} ({auc_improvement*100:+.2f}%)")
    print(f"Specificity Improvement: {spec_improvement:+.3f} ({spec_improvement*100:+.2f}%)")
    
    if multimodal_auc > stage1_auc and multimodal_spec >= stage1_spec:
        print("✅ Hybrid model IMPROVES performance! 🎉")
    else:
        print("⚠️  Similar performance - OCTA adds robustness")

