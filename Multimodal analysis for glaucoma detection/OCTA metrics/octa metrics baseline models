        print(f"   T-test p-value: {p_value_ttest:.4f} {'***' if p_value_ttest < 0.001 else '**' if p_value_ttest < 0.01 else '*' if p_value_ttest < 0.05 else 'ns'}")
        print(f"   MW-test p-value: {p_value_mw:.4f} {'***' if p_value_mw < 0.001 else '**' if p_value_mw < 0.01 else '*' if p_value_mw < 0.05 else 'ns'}")

if __name__ == "__main__":
    main()
