        print(f"   🛡️  Specificity:  {best_cv_result['test_specificity'].mean():.3f}")
    
    # Confusion Matrix for best model
    plt.figure(figsize=(8, 6))
    cm = confusion_matrix(y_test, best_result['predictions'])
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', 
                xticklabels=['Normal', 'Glaucoma'],
                yticklabels=['Normal', 'Glaucoma'])
    plt.title(f'Confusion Matrix - {best_model_name}\n(AUC: {best_result["auc"]:.3f})', fontweight='bold')
    plt.ylabel('True Label', fontweight='bold')
    plt.xlabel('Predicted Label', fontweight='bold')
    plt.tight_layout()
    plt.show()
    
    # ROC Curve for all models
    plt.figure(figsize=(10, 8))
    for name, result in results.items():
