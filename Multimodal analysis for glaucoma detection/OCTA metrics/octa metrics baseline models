# Set random seed for reproducibility
np.random.seed(42)

def clean_column_names(df):
    """Clean column names by stripping whitespace and standardizing"""
    df.columns = [col.strip() for col in df.columns]
    return df

def find_matching_column(df, target_name):
    """Find the best matching column name with fuzzy matching"""
    available_columns = list(df.columns)
    target_clean = target_name.strip().lower()
    
    # Try exact match first
    if target_name in available_columns:
        return target_name
    
    # Try case-insensitive match
    lower_columns = [col.lower() for col in available_columns]
    if target_clean in lower_columns:
        return available_columns[lower_columns.index(target_clean)]
    
    # Try matching with different spacings
    target_no_space = target_clean.replace(' ', '')
    for col in available_columns:
        if col.lower().replace(' ', '') == target_no_space:
            return col
    
    # Try partial matching
    for col in available_columns:
        if target_clean in col.lower() or col.lower() in target_clean:
            return col
    
    return None

def clean_numeric_data(series):
    """Clean numeric data by handling common issues"""
    # Convert to string first
    series = series.astype(str)
    
    # Fix common issues: multiple decimals, commas, etc.
    series = series.str.replace('..', '.', regex=False)  # Fix double decimal points
    series = series.str.replace(',', '.', regex=False)   # Replace commas with dots
    series = series.str.replace(' ', '', regex=False)    # Remove spaces
    
    # Convert to numeric, coercing errors to NaN
    return pd.to_numeric(series, errors='coerce')

def sensitivity_score(y_true, y_pred):
    """Calculate sensitivity (recall) score"""
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    return tp / (tp + fn)

def specificity_score(y_true, y_pred):
    """Calculate specificity score"""
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    return tn / (tn + fp)

def load_real_data():
    """Load the actual OCTA dataset with proper glaucoma labeling"""
    # Load the blood flow CSV
    df = pd.read_csv("Ai in Medicine - Neeraja and Ridhima/blood flow.csv")
    
    # Clean column names first
    df = clean_column_names(df)
    
    print("📊 Available columns in blood flow CSV (after cleaning):")
    for i, col in enumerate(df.columns):
        print(f"   {i+1:2d}. '{col}'")
    
    # Get the actual image files from glaucoma and normal folders
    glaucoma_folder = "Ai in Medicine - Neeraja and Ridhima/Dataset/Glaucoma"
    normal_folder = "Ai in Medicine - Neeraja and Ridhima/Dataset/Normal"
    
    # Extract patient ID from image filenames (format: 1_OD.png, 190_OS.png, etc.)
    def extract_id_from_filename(filename):
        """Extract ID from filename like 1_OD.png -> 1"""
        return filename.split('_')[0]
    
    # Get glaucoma cases
    glaucoma_files = []
    if os.path.exists(glaucoma_folder):
        print(f"\n🔍 Scanning glaucoma folder: {glaucoma_folder}")
        for file in os.listdir(glaucoma_folder):
            if file.endswith(('.png', '.jpg', '.jpeg')):
                patient_id = extract_id_from_filename(file)
                glaucoma_files.append(patient_id)
        print(f"   Found {len(glaucoma_files)} glaucoma images")
    
    # Get normal cases  
    normal_files = []
    if os.path.exists(normal_folder):
        print(f"🔍 Scanning normal folder: {normal_folder}")
        for file in os.listdir(normal_folder):
            if file.endswith(('.png', '.jpg', '.jpeg')):
                patient_id = extract_id_from_filename(file)
                normal_files.append(patient_id)
        print(f"   Found {len(normal_files)} normal images")
    
    # Find the ID column in the CSV
    possible_id_columns = ['SNO', 'ID', 'Id', 'Patient', 'PatientID', 'Subject', 'SubjectID', 'No', 'Number']
    id_column = None
    
    for col in possible_id_columns:
        if col in df.columns:
            id_column = col
            break
    
    # If no common ID column found, use the first column
    if id_column is None:
        id_column = df.columns[0]
        print(f"⚠️  No standard ID column found, using first column: '{id_column}'")
    else:
        print(f"✅ Using ID column: '{id_column}'")
    
    # Convert ID column to string for matching
    df['ID_str'] = df[id_column].astype(str).str.strip()
    
    # Also strip any whitespace from the image file IDs
    glaucoma_files = [id.strip() for id in glaucoma_files]
    normal_files = [id.strip() for id in normal_files]
    
    # Create proper glaucoma labels
    df['glaucoma'] = 0  # Initialize all as normal
    
    # Mark glaucoma cases
    glaucoma_mask = df['ID_str'].isin(glaucoma_files)
    df.loc[glaucoma_mask, 'glaucoma'] = 1
    
    # Mark normal cases
    normal_mask = df['ID_str'].isin(normal_files)
    
    print(f"\n✅ Final label distribution:")
    print(f"   Glaucoma: {glaucoma_mask.sum()} cases")
    print(f"   Normal: {normal_mask.sum()} cases")
    print(f"   Unmatched: {len(df) - (glaucoma_mask.sum() + normal_mask.sum())} cases")
    
    # Show some examples of matches
    if glaucoma_mask.sum() > 0:
        print(f"\n🔍 Glaucoma match examples:")
        glaucoma_samples = df[glaucoma_mask].head(3)
        for _, row in glaucoma_samples.iterrows():
            print(f"   ID: '{row['ID_str']}' -> Glaucoma")
    
    if normal_mask.sum() > 0:
        print(f"🔍 Normal match examples:")
        normal_samples = df[normal_mask].head(3)
        for _, row in normal_samples.iterrows():
            print(f"   ID: '{row['ID_str']}' -> Normal")
    
    return df

def compute_metrics(y_true, y_pred, y_probs):
    """Compute comprehensive evaluation metrics"""
    auc = roc_auc_score(y_true, y_probs)
    acc = accuracy_score(y_true, y_pred)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()
    sens = tp / (tp + fn)
    spec = tn / (tn + fp)
    return auc, acc, sens, spec

def evaluate_model(model, X_train, X_test, y_train, y_test, model_name=""):
    """Evaluate a model and return comprehensive metrics"""
    # Train the model
    model.fit(X_train, y_train)
    
    # Make predictions
    y_pred = model.predict(X_test)
    y_probs = model.predict_proba(X_test)[:, 1]
    
    # Compute metrics
    auc, acc, sens, spec = compute_metrics(y_test, y_pred, y_probs)
    
    return {
        'model': model_name,
        'auc': auc,
        'accuracy': acc,
        'sensitivity': sens,
        'specificity': spec,
        'predictions': y_pred,
        'probabilities': y_probs
    }

def plot_feature_importance(features, importance, title):
    """Plot feature importance"""
    plt.figure(figsize=(12, 6))
    indices = np.argsort(importance)[::-1]
    plt.bar(range(len(features)), importance[indices], color='skyblue', edgecolor='black')
    plt.xticks(range(len(features)), [features[i] for i in indices], rotation=45, ha='right')
    plt.title(title, fontsize=14, fontweight='bold')
    plt.ylabel('Importance', fontweight='bold')
    plt.grid(axis='y', alpha=0.3)
    plt.tight_layout()
    plt.show()

def main():
    print("🔬 MODEL WITH STATISTICALLY SIGNIFICANT FEATURES - REAL DATA")
    print("=" * 70)
    
    # Load real data
    df = load_real_data()
    
    # Target features we want to find
    target_features = [
        'I flux ONH',      # 1. I flux ONH
        'I per ONH',       # 2. I per ONH 
        'S per ONH',       # 3. S per ONH 
        'SS ONH/10',       # 4. SS ONH/10
        'S flux ONH',      # 5. S flux ONH
        '3x3_vsl_inner',   # 6. 3x3_vsl_inner
        'TOT flux ONH'     # 7. TOT flux ONH
    ]
    
    # Find matching columns in the dataset
    features = []
    found_features = []
    missing_features = []
    
    print(f"\n🔍 Looking for features in dataset:")
    for target_feature in target_features:
        matched_col = find_matching_column(df, target_feature)
        if matched_col:
            features.append(matched_col)
            found_features.append((target_feature, matched_col))
            print(f"   ✅ '{target_feature}' -> found as '{matched_col}'")
        else:
            missing_features.append(target_feature)
            print(f"   ❌ '{target_feature}' -> NOT FOUND")
    
    if not features:
        print("❌ No features found in dataset!")
        return
    
    print(f"\n📊 Using {len(features)} features:")
    for i, (original, found) in enumerate(found_features, 1):
        print(f"   {i}. {found}")
    
    # Clean the data for each feature
    print(f"\n🧹 Cleaning feature data...")
    for feature in features:
        df[feature] = clean_numeric_data(df[feature])
        missing_before = df[feature].isna().sum()
        print(f"   {feature}: {missing_before} missing values after cleaning")
    
    # Prepare the data
    X = df[features].values
    y = df['glaucoma'].values
    
    # Handle missing values
    from sklearn.impute import SimpleImputer
    imputer = SimpleImputer(strategy='median')
    X = imputer.fit_transform(X)
    
    print(f"\n📈 Real dataset loaded:")
    print(f"   Samples: {X.shape[0]}")
    print(f"   Features: {X.shape[1]}")
    print(f"   Glaucoma cases: {np.sum(y)} ({np.mean(y)*100:.1f}%)")
    print(f"   Normal cases: {np.sum(1-y)} ({np.mean(1-y)*100:.1f}%)")
    
    # Create DataFrame for better visualization
    feature_df = pd.DataFrame(X, columns=features)
    feature_df['target'] = y
    
    print("\n📋 Feature Statistics:")
    print(feature_df.describe())
    
    # Correlation analysis
    print("\n📊 Feature Correlations with Target:")
    correlations = feature_df.corr()['target'].drop('target')
    for feature, corr in correlations.items():
        significance = "↑" if corr > 0 else "↓"
        print(f"   {feature:15}: {corr:+.3f} {significance}")
    
    # Split the data
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.3, random_state=42, stratify=y
    )
    
    # Scale the features
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)
    
    print(f"\n📊 Training set: {X_train.shape[0]} samples")
    print(f"📊 Test set: {X_test.shape[0]} samples")
    
    # Initialize models
    models = {
        'Logistic Regression': LogisticRegression(random_state=42, max_iter=1000),
        'Random Forest': RandomForestClassifier(n_estimators=100, random_state=42),
        'SVM': SVC(probability=True, random_state=42)
    }
    
    results = {}
    
    print("\n🚀 TRAINING MODELS...")
    print("=" * 50)
    
    # Train and evaluate each model
    for name, model in models.items():
        print(f"\n📊 Evaluating {name}...")
        
        if name == 'SVM':
            # Use scaled data for SVM
            result = evaluate_model(model, X_train_scaled, X_test_scaled, y_train, y_test, name)
        else:
            result = evaluate_model(model, X_train, X_test, y_train, y_test, name)
        
        results[name] = result
        
        print(f"   AUC:          {result['auc']:.4f}")
        print(f"   Accuracy:     {result['accuracy']:.3f}")
        print(f"   Sensitivity:  {result['sensitivity']:.3f}")
        print(f"   Specificity:  {result['specificity']:.3f}")
    
    # Enhanced Cross-validation with sensitivity and specificity
    print(f"\n🔍 5-FOLD CROSS-VALIDATION RESULTS (with Sensitivity & Specificity)")
    print("=" * 70)
    
    cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
    
    # Define custom scorers for sensitivity and specificity
    scorers = {
        'auc': 'roc_auc',
        'accuracy': 'accuracy',
        'sensitivity': make_scorer(sensitivity_score),
        'specificity': make_scorer(specificity_score)
    }
    
    for name, model in models.items():
        print(f"\n{name}:")
        
        if name == 'SVM':
            X_cv = X_train_scaled
        else:
            X_cv = X_train
            
        # Perform cross-validation with multiple metrics
        cv_results = cross_validate(model, X_cv, y_train, cv=cv, scoring=scorers)
        
        # Print results for each metric
        print(f"   AUC:          {cv_results['test_auc'].mean():.4f} ± {cv_results['test_auc'].std():.4f}")
        print(f"   Accuracy:     {cv_results['test_accuracy'].mean():.3f} ± {cv_results['test_accuracy'].std():.3f}")
        print(f"   Sensitivity:  {cv_results['test_sensitivity'].mean():.3f} ± {cv_results['test_sensitivity'].std():.3f}")
        print(f"   Specificity:  {cv_results['test_specificity'].mean():.3f} ± {cv_results['test_specificity'].std():.3f}")
        
        # Store CV results for comparison
        if 'cv_results' not in results[name]:
            results[name]['cv_results'] = {}
        results[name]['cv_results'] = cv_results
    
    # Feature importance analysis
    print(f"\n🎯 FEATURE IMPORTANCE ANALYSIS")
    print("=" * 40)
    
    # Random Forest feature importance
    rf_model = RandomForestClassifier(n_estimators=100, random_state=42)
    rf_model.fit(X_train, y_train)
    
    importance = rf_model.feature_importances_
    
    print("\nRandom Forest Feature Importance:")
    for i, (feature, imp) in enumerate(zip(features, importance)):
        print(f"   {i+1}. {feature:15}: {imp:.4f}")
    
    # Plot feature importance
    plot_feature_importance(features, importance, "Random Forest Feature Importance")
    
    # Logistic Regression coefficients
    lr_model = LogisticRegression(random_state=42, max_iter=1000)
    lr_model.fit(X_train_scaled, y_train)
    
    coefficients = lr_model.coef_[0]
    
    print("\nLogistic Regression Coefficients (scaled features):")
