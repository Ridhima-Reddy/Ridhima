        if 'cv_results' in result:
            cv_comparison.append({
                'Model': name,
                'AUC': f"{result['cv_results']['test_auc'].mean():.4f} ± {result['cv_results']['test_auc'].std():.4f}",
                'Accuracy': f"{result['cv_results']['test_accuracy'].mean():.3f} ± {result['cv_results']['test_accuracy'].std():.3f}",
                'Sensitivity': f"{result['cv_results']['test_sensitivity'].mean():.3f} ± {result['cv_results']['test_sensitivity'].std():.3f}",
                'Specificity': f"{result['cv_results']['test_specificity'].mean():.3f} ± {result['cv_results']['test_specificity'].std():.3f}"
