# ------------------------- P-VALUE FOCUSED STEPWISE SELECTION -------------------------

def find_best_column_match(df, target_column):
    """Find the best matching column name using fuzzy matching"""
    available_columns = list(df.columns)
    
    # Try exact match first
    if target_column in available_columns:
        return target_column
    
    # Try case-insensitive match
    lower_columns = [col.lower() for col in available_columns]
    if target_column.lower() in lower_columns:
        return available_columns[lower_columns.index(target_column.lower())]
    
    # Try fuzzy matching
    matches = difflib.get_close_matches(target_column, available_columns, n=1, cutoff=0.6)
    if matches:
        return matches[0]
    
    # If no match found, return None
    return None

def load_and_prepare_data():
    """Load OCTA data and prepare for analysis with proper glaucoma labeling"""
    df = pd.read_csv("Ai in Medicine - Neeraja and Ridhima/blood flow.csv")
    
    # First, let's see what columns we actually have
    print("📊 ALL COLUMNS IN CSV FILE:")
    print("=" * 50)
    for i, col in enumerate(df.columns):
        print(f"   {i+1:2d}. '{col}'")
    print("=" * 50)
    
    # Get the actual image files from glaucoma and normal folders
    glaucoma_folder = "Ai in Medicine - Neeraja and Ridhima/Dataset/Glaucoma"
    normal_folder = "Ai in Medicine - Neeraja and Ridhima/Dataset/Normal"
    
    # Extract patient ID from image filenames (format: 1_OD.png, 190_OS.png, etc.)
    def extract_id_from_filename(filename):
        """Extract ID from filename like 1_OD.png -> 1"""
        return filename.split('_')[0]
    
    # Get glaucoma cases
    glaucoma_files = []
    if os.path.exists(glaucoma_folder):
        print(f"🔍 Scanning glaucoma folder: {glaucoma_folder}")
        for file in os.listdir(glaucoma_folder):
            if file.endswith(('.png', '.jpg', '.jpeg')):
                patient_id = extract_id_from_filename(file)
                glaucoma_files.append(patient_id)
        print(f"   Found {len(glaucoma_files)} glaucoma images")
    
    # Get normal cases  
    normal_files = []
    if os.path.exists(normal_folder):
        print(f"🔍 Scanning normal folder: {normal_folder}")
        for file in os.listdir(normal_folder):
            if file.endswith(('.png', '.jpg', '.jpeg')):
                patient_id = extract_id_from_filename(file)
                normal_files.append(patient_id)
        print(f"   Found {len(normal_files)} normal images")
    
    print(f"\n📁 Total images found: {len(glaucoma_files) + len(normal_files)}")
    
    # Create proper glaucoma labels based on ID matching
    df['glaucoma'] = 0  # Initialize all as normal
    
    # Find the best matching column for SNO
    sno_column = find_best_column_match(df, 'SNO')
    
    if sno_column:
        print(f"✅ Found matching column for 'SNO': '{sno_column}'")
    else:
        # Try other common ID column names
        possible_id_columns = ['ID', 'Id', 'Patient', 'PatientID', 'Subject', 'SubjectID', 'No', 'Number']
        for possible_col in possible_id_columns:
            matched_col = find_best_column_match(df, possible_col)
            if matched_col:
                sno_column = matched_col
                print(f"✅ Using '{sno_column}' as ID column (matched to '{possible_col}')")
                break
        
        # If still no match, use the first column
        if not sno_column:
            sno_column = df.columns[0]
            print(f"⚠️  No ID column found, using first column: '{sno_column}'")
    
    # Convert ID column to string for matching
    df['ID_str'] = df[sno_column].astype(str).str.strip()
    
    # Also strip any whitespace from the image file IDs
    glaucoma_files = [id.strip() for id in glaucoma_files]
    normal_files = [id.strip() for id in normal_files]
    
    # Mark glaucoma cases
    glaucoma_mask = df['ID_str'].isin(glaucoma_files)
    df.loc[glaucoma_mask, 'glaucoma'] = 1
    
    # Mark normal cases
    normal_mask = df['ID_str'].isin(normal_files)
    
    print(f"\n✅ Label distribution:")
    print(f"   Glaucoma: {glaucoma_mask.sum()} cases")
    print(f"   Normal: {normal_mask.sum()} cases")
    print(f"   Unmatched: {len(df) - (glaucoma_mask.sum() + normal_mask.sum())} cases")
    
    # Show some examples of matches
    if glaucoma_mask.sum() > 0:
        print(f"\n🔍 Glaucoma match examples:")
        glaucoma_samples = df[glaucoma_mask].head(3)
        for _, row in glaucoma_samples.iterrows():
            print(f"   ID: '{row['ID_str']}' -> Glaucoma")
    
    if normal_mask.sum() > 0:
        print(f"🔍 Normal match examples:")
        normal_samples = df[normal_mask].head(3)
        for _, row in normal_samples.iterrows():
            print(f"   ID: '{row['ID_str']}' -> Normal")
    
    # Show unmatched examples if any
    unmatched_mask = ~glaucoma_mask & ~normal_mask
    if unmatched_mask.sum() > 0:
        print(f"🔍 Unmatched examples:")
        unmatched_samples = df[unmatched_mask].head(3)
        for _, row in unmatched_samples.iterrows():
            print(f"   ID: '{row['ID_str']}' -> Unmatched")
    
    # Identify OCTA features (exclude metadata)
    exclude_cols = [sno_column, 'ID_str', 'Date', 'Age', 'Gender', 'Eye', 'Lens status', 
                   'OD_SPH', 'OD_CYL', 'OD_AXIS', 'SE', 'glaucoma']
    # Only include columns that actually exist in the dataframe
    exclude_cols = [col for col in exclude_cols if col in df.columns]
    
    octa_features = [col for col in df.columns if col not in exclude_cols]
    
    # Clean numeric data
    for feature in octa_features:
        df[feature] = pd.to_numeric(df[feature], errors='coerce')
    
    print(f"\n✅ Clean data: {len(df)} samples, {len(octa_features)} OCTA features")
    print(f"📊 First 10 OCTA features: {octa_features[:10]}")
    if len(octa_features) > 10:
        print(f"   ... and {len(octa_features) - 10} more features")
    
    return df, octa_features

def evaluate_model_p_values(df, features, target='glaucoma'):
    """Evaluate model and return p-values (main focus)"""
    if len(features) == 0:
        return {'features': [], 'p_values': [], 'max_p': 1.0, 'mean_p': 1.0, 'significant_count': 0}
    
    X = df[features].copy()
    y = df[target].copy()
    
    # Handle missing values
    X = X.fillna(X.mean())
    valid_mask = X.notna().all(axis=1)
    X = X[valid_mask]
    y = y[valid_mask]
    
    if len(X) < 10 or len(np.unique(y)) < 2:
        return {'features': features, 'p_values': [], 'max_p': 1.0, 'mean_p': 1.0, 'significant_count': 0}
    
    try:
        # Standardize
        scaler = StandardScaler()
        X_scaled = scaler.fit_transform(X)
        X_scaled_df = pd.DataFrame(X_scaled, columns=features)
        
        # Add constant
        X_sm = sm.add_constant(X_scaled_df)
        
        # Fit model
        model = sm.Logit(y, X_sm)
        result = model.fit(disp=False, maxiter=1000)
        
        # Focus on p-values
        p_values = result.pvalues[1:].values  # Exclude intercept
        max_p = np.max(p_values)
        mean_p = np.mean(p_values)
        significant_count = sum(p_values < 0.05)
        
        return {
            'features': features,
            'p_values': p_values,
            'max_p': max_p,
            'mean_p': mean_p,
            'significant_count': significant_count,
            'all_significant': all(p_values < 0.05),
            'n_samples': len(X),
            'auc': result.prsquared  # Pseudo R-squared as performance measure
        }
    except:
        return {'features': features, 'p_values': [], 'max_p': 1.0, 'mean_p': 1.0, 'significant_count': 0}

def p_value_forward_selection(df, features, target='glaucoma', p_enter=0.05, max_features=15):
    """Forward selection based on p-values"""
    print("🔼 P-VALUE FORWARD SELECTION")
    print("="*50)
    
    selected_features = []
    remaining_features = features.copy()
    history = []
    
    # Start with empty model
    current_model = evaluate_model_p_values(df, [])
    history.append(current_model)
    print(f"Step 0: No features, Max p: -")
    
    step = 1
    while remaining_features and len(selected_features) < max_features:
        best_candidate = None
        best_p_value = p_enter  # Only consider features with p < threshold
        
        # Test each remaining feature
        for feature in remaining_features:
            candidate_features = selected_features + [feature]
            candidate_model = evaluate_model_p_values(df, candidate_features)
            
            if len(candidate_model['p_values']) > 0:
                candidate_p = candidate_model['p_values'][-1]  # p-value of the new feature
                
                # Only consider if p-value is significant and better than current best
                if candidate_p < best_p_value:
                    best_p_value = candidate_p
                    best_candidate = feature
                    best_model = candidate_model
        
        # Add the best candidate if it meets p-value threshold
        if best_candidate and best_p_value < p_enter:
            selected_features.append(best_candidate)
            remaining_features.remove(best_candidate)
            current_model = best_model
            
            print(f"Step {step}: +{best_candidate}")
            print(f"   P-value: {best_p_value:.4f}")
            print(f"   Max p in model: {current_model['max_p']:.4f}")
            print(f"   Significant features: {current_model['significant_count']}/{len(selected_features)}")
            print(f"   Features: {len(selected_features)}")
            
            history.append(current_model)
            step += 1
        else:
            print(f"❌ No features meet p-value threshold (p < {p_enter}) - stopping")
            break
    
    print(f"✅ Forward selection completed: {len(selected_features)} features selected")
    return selected_features, history

def p_value_backward_selection(df, features, target='glaucoma', p_remove=0.05):
    """Backward selection based on p-values"""
    print("\n🔽 P-VALUE BACKWARD SELECTION")
    print("="*50)
    
    # Start with all features
    current_features = features.copy()
    current_model = evaluate_model_p_values(df, current_features)
    history = [current_model]
    
    print(f"Step 0: All {len(features)} features")
    print(f"   Max p: {current_model['max_p']:.4f}")
    print(f"   Significant: {current_model['significant_count']}/{len(features)}")
    
    step = 1
    improved = True
    
    while improved and len(current_features) > 1:
        improved = False
        
        # Find feature with highest p-value
        worst_feature = None
        worst_p_value = 0
        
        for i, feature in enumerate(current_features):
            if i < len(current_model['p_values']):
                feature_p = current_model['p_values'][i]
                if feature_p > worst_p_value:
                    worst_p_value = feature_p
                    worst_feature = feature
        
        # Remove feature if p-value > threshold
        if worst_feature and worst_p_value > p_remove:
            current_features.remove(worst_feature)
            current_model = evaluate_model_p_values(df, current_features)
            improved = True
            
            print(f"Step {step}: -{worst_feature}")
            print(f"   P-value: {worst_p_value:.4f}")
            print(f"   New max p: {current_model['max_p']:.4f}")
            print(f"   Significant: {current_model['significant_count']}/{len(current_features)}")
            
            history.append(current_model)
            step += 1
        else:
            print("✅ All remaining features are significant (p < 0.05)")
            break
    
    print(f"✅ Backward selection completed: {len(current_features)} features remaining")
    return current_features, history

def p_value_stepwise_selection(df, features, target='glaucoma', p_enter=0.05, p_remove=0.1, max_features=15):
    """Stepwise selection focused on p-values"""
    print("\n🔄 P-VALUE STEPWISE SELECTION")
    print("="*50)
    
    selected_features = []
    remaining_features = features.copy()
    history = []
    
    # Start with empty model
    current_model = evaluate_model_p_values(df, [])
    history.append(current_model)
    print(f"Initial: No features")
    
    step = 1
    while remaining_features and len(selected_features) < max_features:
        # FORWARD STEP: Find feature with best p-value
        best_forward = None
        best_forward_p = p_enter
        
        for feature in remaining_features:
            candidate_features = selected_features + [feature]
            candidate_model = evaluate_model_p_values(df, candidate_features)
            
            if len(candidate_model['p_values']) > 0:
                candidate_p = candidate_model['p_values'][-1]
                
                if candidate_p < best_forward_p:
                    best_forward_p = candidate_p
                    best_forward = feature
                    best_forward_model = candidate_model
        
        # Add feature if p-value significant
        if best_forward and best_forward_p < p_enter:
            selected_features.append(best_forward)
            remaining_features.remove(best_forward)
            current_model = best_forward_model
            
            print(f"Step {step} [FORWARD]: +{best_forward}")
            print(f"   P-value: {best_forward_p:.4f}")
            print(f"   Current features: {len(selected_features)}")
            
            history.append(current_model)
            step += 1
            
            # BACKWARD STEP: Remove features with high p-values
            backward_improved = True
            while backward_improved and len(selected_features) > 1:
                backward_improved = False
                
                # Find feature with highest p-value
                worst_backward = None
                worst_backward_p = 0
                
                for i, feature in enumerate(selected_features):
                    if i < len(current_model['p_values']):
                        feature_p = current_model['p_values'][i]
                        if feature_p > worst_backward_p:
                            worst_backward_p = feature_p
                            worst_backward = feature
                
                # Remove if p-value too high
                if worst_backward and worst_backward_p > p_remove:
                    selected_features.remove(worst_backward)
                    remaining_features.append(worst_backward)
                    current_model = evaluate_model_p_values(df, selected_features)
                    backward_improved = True
                    
                    print(f"Step {step} [BACKWARD]: -{worst_backward}")
                    print(f"   P-value: {worst_backward_p:.4f}")
                    print(f"   Current features: {len(selected_features)}")
                    
                    history.append(current_model)
                    step += 1
        else:
            print(f"❌ No features meet p-value threshold (p < {p_enter})")
            break
    
    print(f"✅ Stepwise selection completed: {len(selected_features)} features selected")
    return selected_features, history

def compare_p_value_methods(df, features):
    """Compare all three p-value based methods"""
    print("🎯 COMPARING P-VALUE SELECTION METHODS")
    print("="*60)
    
    results = {}
    
    # 1. Forward Selection
    print("\n1. FORWARD SELECTION (p < 0.05 to enter)")
    forward_features, forward_history = p_value_forward_selection(df, features)
    if forward_history:
        best_forward = forward_history[-1]
        results['forward'] = {
            'features': forward_features,
            'max_p': best_forward['max_p'],
            'mean_p': best_forward['mean_p'],
            'significant_count': best_forward['significant_count'],
            'n_features': len(forward_features)
        }
    
    # 2. Backward Selection  
    print("\n2. BACKWARD SELECTION (p > 0.05 to remove)")
    backward_features, backward_history = p_value_backward_selection(df, features)
    if backward_history:
        best_backward = backward_history[-1]
        results['backward'] = {
            'features': backward_features,
            'max_p': best_backward['max_p'],
            'mean_p': best_backward['mean_p'],
            'significant_count': best_backward['significant_count'],
            'n_features': len(backward_features)
        }
    
    # 3. Stepwise Selection
    print("\n3. STEPWISE SELECTION (p < 0.05 to enter, p > 0.1 to remove)")
    stepwise_features, stepwise_history = p_value_stepwise_selection(df, features)
    if stepwise_history:
        best_stepwise = stepwise_history[-1]
        results['stepwise'] = {
            'features': stepwise_features,
            'max_p': best_stepwise['max_p'],
            'mean_p': best_stepwise['mean_p'],
            'significant_count': best_stepwise['significant_count'],
            'n_features': len(stepwise_features)
        }
    
    # Compare results
    print("\n🏆 FINAL COMPARISON (P-VALUE FOCUSED)")
    print("="*50)
    for method, result in results.items():
        print(f"{method.upper():>10}: {result['n_features']:2d} features, "
              f"Max p: {result['max_p']:.4f}, "
              f"Significant: {result['significant_count']}/{result['n_features']}")
    
    # Find best method (lowest maximum p-value)
    if results:
        best_method = min(results.items(), key=lambda x: x[1]['max_p'])
        print(f"\n🎯 BEST METHOD: {best_method[0].upper()} (Lowest maximum p-value)")
        print(f"   Features: {best_method[1]['n_features']}")
        print(f"   Maximum p-value: {best_method[1]['max_p']:.4f}")
        print(f"   Significant features: {best_method[1]['significant_count']}/{best_method[1]['n_features']}")
        print(f"   Mean p-value: {best_method[1]['mean_p']:.4f}")
        print(f"   Selected features:")
        for i, feature in enumerate(best_method[1]['features'], 1):
            print(f"      {i}. {feature}")
        
        return best_method[1]['features']
    
    return []

def final_p_value_analysis(df, selected_features, target='glaucoma'):
    """Detailed p-value analysis of final selected features"""
    if not selected_features:
        print("❌ No features selected for final analysis")
        return
    
    print("\n" + "="*60)
    print("📊 FINAL P-VALUE ANALYSIS")
    print("="*60)
    
    result = evaluate_model_p_values(df, selected_features, target)
    
    if 'p_values' in result and len(result['p_values']) > 0:
        print(f"📈 Model Summary:")
        print(f"   • Features: {len(selected_features)}")
        print(f"   • Significant features: {result['significant_count']}/{len(selected_features)}")
        print(f"   • Maximum p-value: {result['max_p']:.4f}")
        print(f"   • Mean p-value: {result['mean_p']:.4f}")
        print(f"   • Samples: {result['n_samples']}")
        
        print(f"\n🔬 Individual Feature P-values:")
        feature_p_df = pd.DataFrame({
            'Feature': selected_features,
            'P-value': result['p_values']
        }).sort_values('P-value')
        
        for i, (_, row) in enumerate(feature_p_df.iterrows(), 1):
            significance = "✅" if row['P-value'] < 0.05 else "⚠️ "
            stars = "***" if row['P-value'] < 0.001 else "**" if row['P-value'] < 0.01 else "*" if row['P-value'] < 0.05 else ""
            print(f"   {i:2d}. {significance} {row['Feature']}: {row['P-value']:.4f} {stars}")
    
    return result

# ------------------------- MAIN EXECUTION -------------------------

def main():
    """Main function for p-value based feature selection"""
    print("🎯 P-VALUE BASED FEATURE SELECTION FOR OCTA METRICS")
    print("="*60)
    print("📊 Selection Criteria: Statistical Significance (p < 0.05)")
    print("="*60)
    
    # 1. Load data with proper glaucoma labeling
    df, features = load_and_prepare_data()
    
    # 2. Use all features for analysis
    print(f"🔍 Analyzing ALL {len(features)} features using p-value criteria...")
    
    # 3. Compare p-value selection methods
    best_features = compare_p_value_methods(df, features)
    
    # 4. Detailed p-value analysis
    if best_features:
        final_result = final_p_value_analysis(df, best_features)
        
        print(f"\n✅ P-VALUE SELECTION COMPLETED!")
        print(f"🎯 Final feature set ({len(best_features)} statistically significant features)")
    else:
        print("❌ No statistically significant feature set found")

if __name__ == "__main__":
    main()
